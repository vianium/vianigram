<Page
    x:Class="Vianigram.SmokeRunner.App.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="#FF0F1115">
    <Grid Margin="16,24,16,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <!-- Header -->
            <RowDefinition Height="Auto" />
            <!-- Toggle row -->
            <RowDefinition Height="Auto" />
            <!-- Run button -->
            <RowDefinition Height="Auto" />
            <!-- Status -->
            <RowDefinition Height="Auto" />
            <!-- Summary -->
            <RowDefinition Height="*" />
            <!-- Results list (fills) -->
        </Grid.RowDefinitions>

        <TextBlock
            Grid.Row="0"
            Text="Vianigram smoke tests"
            FontSize="28"
            FontWeight="SemiBold"
            Foreground="#FFF1F5F9"
            Margin="0,0,0,12" />

        <CheckBox
            Grid.Row="1"
            x:Name="LiveTestToggle"
            Content="Include live test (test DC #2)"
            IsChecked="True"
            Foreground="#FFC9D1D9"
            Margin="0,0,0,8" />

        <Button
            Grid.Row="2"
            x:Name="RunButton"
            Content="Run smoke tests"
            HorizontalAlignment="Stretch"
            Background="#FF0078D7"
            Foreground="#FFFFFFFF"
            FontSize="18"
            Padding="0,12,0,12"
            Margin="0,0,0,12"
            Click="RunButton_Click" />

        <TextBlock
            Grid.Row="3"
            x:Name="StatusText"
            Text="Idle"
            FontSize="14"
            Foreground="#FF8B949E"
            Margin="0,0,0,4" />

        <TextBlock
            Grid.Row="4"
            x:Name="SummaryText"
            Text=""
            FontSize="16"
            Foreground="#FFC9D1D9"
            Margin="0,0,0,12"
            TextWrapping="Wrap" />

        <ListView
            Grid.Row="5"
            x:Name="ResultsList"
            Background="#FF161B22"
            BorderBrush="#FF30363D"
            BorderThickness="1"
            ScrollViewer.VerticalScrollBarVisibility="Auto"
            ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="Padding" Value="8,4,8,4" />
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Vertical">
                        <TextBlock
                            Text="{Binding Header}"
                            FontSize="14"
                            FontWeight="SemiBold"
                            Foreground="{Binding HeaderBrush}"
                            TextWrapping="Wrap" />
                        <TextBlock
                            Text="{Binding Detail}"
                            FontSize="12"
                            Foreground="#FF8B949E"
                            TextWrapping="Wrap"
                            Visibility="{Binding HasDetail}" />
                    </StackPanel>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
