  <!-- SQLite for Windows Phone 8.1. The Extension SDK ships the
       native sqlite3.dll inside the appx; Vianigram.Storage P/Invokes against
       it via DllImport("sqlite3"). Microsoft.VCLibs is a required dependency
       per the SDK manifest. -->
  <PropertyGroup>
    <SqliteWp81RedistFlavor Condition=" '$(Configuration)' == 'Debug' ">Debug</SqliteWp81RedistFlavor>
    <SqliteWp81RedistFlavor Condition=" '$(SqliteWp81RedistFlavor)' == '' ">Retail</SqliteWp81RedistFlavor>
    <SqliteWp81Root>C:\Program Files (x86)\Microsoft SDKs\WindowsPhoneApp\v8.1\ExtensionSDKs\SQLite.WP81\3.38.0</SqliteWp81Root>
    <TgcallsNativeOutputDir Condition=" '$(Platform)' == 'ARM' ">$(MSBuildThisFileDirectory)..\..\ARM\$(Configuration)\Vianium.Tgcalls\</TgcallsNativeOutputDir>
    <TgcallsNativeOutputDir Condition=" '$(Platform)' != 'ARM' ">$(MSBuildThisFileDirectory)..\..\$(Configuration)\Vianium.Tgcalls\</TgcallsNativeOutputDir>
  </PropertyGroup>
  <ItemGroup>
    <Content Include="$(SqliteWp81Root)\Redist\$(SqliteWp81RedistFlavor)\$(Platform)\sqlite3.dll">
      <Link>sqlite3.dll</Link>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
    <Content Include="$(TgcallsNativeOutputDir)Vianium.Tgcalls.dll">
      <Link>Vianium.Tgcalls.dll</Link>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
  </ItemGroup>
  <ItemGroup>
    <SDKReference Include="Microsoft.VCLibs, Version=12.0" />
  </ItemGroup>
  <PropertyGroup Condition=" '$(VisualStudioVersion)' == '' or '$(VisualStudioVersion)' &lt; '14.0' ">
    <VisualStudioVersion>14.0</VisualStudioVersion>
  </PropertyGroup>
  <Import Project="$(MSBuildExtensionsPath)\Microsoft\WindowsXaml\v$(VisualStudioVersion)\Microsoft.Windows.UI.Xaml.CSharp.targets" />
  <PropertyGroup>
    <CopyLocalFilesOutputGroupDependsOn>
      $(CopyLocalFilesOutputGroupDependsOn);
      VianigramRemoveDuplicateNativePdbCopyLocal
    </CopyLocalFilesOutputGroupDependsOn>
  </PropertyGroup>
  <Target Name="VianigramRemoveDuplicateNativePdbCopyLocal">
    <ItemGroup>
      <!-- Native project-reference PDBs also enter the package from their VC output
           folders. Drop only the app copy-local PDB entries to avoid APPX1101. -->
      <_VianigramDuplicateNativeAppBinPdb Include="@(ReferenceCopyLocalPaths)"
                                          Condition="'%(ReferenceCopyLocalPaths.Filename)%(ReferenceCopyLocalPaths.Extension)' == 'Vianium.Crypto.pdb'
                                                     or '%(ReferenceCopyLocalPaths.Filename)%(ReferenceCopyLocalPaths.Extension)' == 'Vianigram.Tl.pdb'
                                                     or '%(ReferenceCopyLocalPaths.Filename)%(ReferenceCopyLocalPaths.Extension)' == 'Vianigram.MTProto.pdb'
                                                     or '%(ReferenceCopyLocalPaths.Filename)%(ReferenceCopyLocalPaths.Extension)' == 'Vianium.Tls.pdb'
                                                     or '%(ReferenceCopyLocalPaths.Filename)%(ReferenceCopyLocalPaths.Extension)' == 'Vianium.MtProxy.pdb'
                                                     or '%(ReferenceCopyLocalPaths.Filename)%(ReferenceCopyLocalPaths.Extension)' == 'Vianium.VoIP.pdb'" />
      <ReferenceCopyLocalPaths Remove="@(_VianigramDuplicateNativeAppBinPdb)" />
    </ItemGroup>
  </Target>
