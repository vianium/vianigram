<Page
    x:Class="Vianigram.App.Pages.Media.MediaViewerPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="using:Vianigram.App.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:Vianigram.App.ViewModels.Pages"
    mc:Ignorable="d"
    d:DataContext="{d:DesignInstance Type=vm:MediaViewerPageViewModel, IsDesignTimeCreatable=True}"
    Background="Black">

    <Page.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibility" />
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Top bar: sender, date, close -->
        <Border Grid.Row="0" Background="#66000000" Padding="12,8,12,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Command="{Binding CloseCommand}"
                        Background="Transparent"
                        BorderThickness="0"
                        Padding="6">
                    <TextBlock Text="&#xE0A6;"
                               FontFamily="Segoe UI Symbol"
                               FontSize="20"
                               Foreground="White" />
                </Button>

                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="12,0,0,0">
                    <TextBlock Text="{Binding SenderName}"
                               Foreground="White"
                               FontSize="15"
                               FontWeight="SemiBold"
                               TextTrimming="CharacterEllipsis" />
                    <TextBlock Text="{Binding DateText}"
                               Foreground="White"
                               Opacity="0.7"
                               FontSize="12"
                               Margin="0,2,0,0" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Image (pinch-zoom via ScrollViewer) -->
        <ScrollViewer Grid.Row="1"
                      x:Name="ImageScroller"
                      ZoomMode="Enabled"
                      MinZoomFactor="1"
                      MaxZoomFactor="5"
                      HorizontalScrollMode="Enabled"
                      VerticalScrollMode="Enabled"
                      HorizontalScrollBarVisibility="Hidden"
                      VerticalScrollBarVisibility="Hidden"
                      Background="Black"
                      Visibility="{Binding IsImage, Converter={StaticResource BoolToVisibility}}">
            <Image Source="{Binding Source}"
                   Stretch="Uniform"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center" />
        </ScrollViewer>

        <!-- Video -->
        <MediaElement Grid.Row="1"
                      x:Name="VideoElement"
                      Source="{Binding MediaUri}"
                      AreTransportControlsEnabled="True"
                      Stretch="Uniform"
                      AutoPlay="False"
                      Visibility="{Binding IsVideo, Converter={StaticResource BoolToVisibility}}" />

        <!-- Bottom: caption + actions -->
        <Border Grid.Row="2" Background="#66000000" Padding="12,8,12,8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="{Binding Caption}"
                           Foreground="White"
                           FontSize="14"
                           TextWrapping="Wrap"
                           Margin="0,0,0,8"
                           Visibility="{Binding HasCaption, Converter={StaticResource BoolToVisibility}}" />

                <TextBlock Grid.Row="1"
                           Text="{Binding StatusText}"
                           Foreground="White"
                           Opacity="0.7"
                           FontSize="12"
                           Margin="0,0,0,4" />

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
                            Command="{Binding SaveCommand}"
                            Background="Transparent"
                            BorderBrush="White"
                            Foreground="White"
                            HorizontalAlignment="Stretch"
                            Margin="0,0,4,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE105;"
                                       FontFamily="Segoe UI Symbol"
                                       FontSize="16"
                                       Margin="0,0,6,0" />
                            <TextBlock Text="Save" />
                        </StackPanel>
                    </Button>

                    <Button Grid.Column="1"
                            Command="{Binding ForwardCommand}"
                            Background="Transparent"
                            BorderBrush="White"
                            Foreground="White"
                            HorizontalAlignment="Stretch"
                            Margin="4,0,4,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE111;"
                                       FontFamily="Segoe UI Symbol"
                                       FontSize="16"
                                       Margin="0,0,6,0" />
                            <TextBlock Text="Forward" />
                        </StackPanel>
                    </Button>

                    <Button Grid.Column="2"
                            Command="{Binding ShareCommand}"
                            Background="Transparent"
                            BorderBrush="White"
                            Foreground="White"
                            HorizontalAlignment="Stretch"
                            Margin="4,0,0,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE12B;"
                                       FontFamily="Segoe UI Symbol"
                                       FontSize="16"
                                       Margin="0,0,6,0" />
                            <TextBlock Text="Share" />
                        </StackPanel>
                    </Button>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Page>
