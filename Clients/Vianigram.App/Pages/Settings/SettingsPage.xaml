<Page
    x:Class="Vianigram.App.Pages.Settings.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:Vianigram.App.Controls"
    xmlns:vm="using:Vianigram.App.ViewModels.Pages"
    mc:Ignorable="d"
    d:DataContext="{d:DesignInstance Type=vm:SettingsPageViewModel, IsDesignTimeCreatable=True}"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Page.Resources>
        <Style x:Key="SettingsRowButtonStyle" TargetType="Button">
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="16,14" />
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0"
                   Text="Settings"
                   FontSize="28"
                   FontWeight="SemiBold"
                   Foreground="{ThemeResource ApplicationForegroundThemeBrush}"
                   Margin="20,12,20,8" />

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- Profile section: tap to edit -->
                <Button Background="Transparent"
                        BorderThickness="0"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Stretch"
                        Padding="16,12"
                        Command="{Binding EditProfileCommand}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <controls:AvatarCircle Grid.Column="0"
                                               AvatarSize="64"
                                               Initials="{Binding AvatarLetter, Mode=OneWay}" />

                        <StackPanel Grid.Column="2"
                                    VerticalAlignment="Center">
                            <TextBlock Text="{Binding DisplayName, Mode=OneWay}"
                                       FontSize="20"
                                       FontWeight="SemiBold"
                                       Foreground="{ThemeResource ApplicationForegroundThemeBrush}"
                                       TextTrimming="CharacterEllipsis" />
                            <TextBlock Text="{Binding Phone, Mode=OneWay}"
                                       FontSize="13"
                                       Opacity="0.6"
                                       Margin="0,4,0,0" />
                            <TextBlock Text="Tap to edit profile"
                                       FontSize="12"
                                       Opacity="0.5"
                                       Margin="0,4,0,0" />
                        </StackPanel>
                    </Grid>
                </Button>

                <Border Height="1"
                        Background="{ThemeResource SystemControlForegroundBaseLowBrush}"
                        Margin="16,0" />

                <!-- Section rows -->
                <Button Style="{StaticResource SettingsRowButtonStyle}"
                        Command="{Binding NotificationsCommand}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="32" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="&#xE0A4;" FontFamily="Segoe UI Symbol" VerticalAlignment="Center" Foreground="{ThemeResource SystemControlForegroundAccentBrush}" />
                        <TextBlock Grid.Column="1" Text="Notifications and Sounds" VerticalAlignment="Center" Foreground="{ThemeResource ApplicationForegroundThemeBrush}" />
                        <TextBlock Grid.Column="2" Text="&#xE26B;" FontFamily="Segoe UI Symbol" VerticalAlignment="Center" Opacity="0.5" />
                    </Grid>
                </Button>

                <Button Style="{StaticResource SettingsRowButtonStyle}"
                        Command="{Binding PrivacyCommand}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="32" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="&#xE192;" FontFamily="Segoe UI Symbol" VerticalAlignment="Center" Foreground="{ThemeResource SystemControlForegroundAccentBrush}" />
                        <TextBlock Grid.Column="1" Text="Privacy and Security" VerticalAlignment="Center" Foreground="{ThemeResource ApplicationForegroundThemeBrush}" />
                        <TextBlock Grid.Column="2" Text="&#xE26B;" FontFamily="Segoe UI Symbol" VerticalAlignment="Center" Opacity="0.5" />
                    </Grid>
                </Button>

                <Button Style="{StaticResource SettingsRowButtonStyle}"
                        Command="{Binding DataStorageCommand}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="32" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="&#xE159;" FontFamily="Segoe UI Symbol" VerticalAlignment="Center" Foreground="{ThemeResource SystemControlForegroundAccentBrush}" />
                        <TextBlock Grid.Column="1" Text="Data and Storage" VerticalAlignment="Center" Foreground="{ThemeResource ApplicationForegroundThemeBrush}" />
                        <TextBlock Grid.Column="2" Text="&#xE26B;" FontFamily="Segoe UI Symbol" VerticalAlignment="Center" Opacity="0.5" />
                    </Grid>
                </Button>

                <Button Style="{StaticResource SettingsRowButtonStyle}"
                        Command="{Binding ChatSettingsCommand}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="32" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="&#xE15F;" FontFamily="Segoe UI Symbol" VerticalAlignment="Center" Foreground="{ThemeResource SystemControlForegroundAccentBrush}" />
                        <TextBlock Grid.Column="1" Text="Chat Settings" VerticalAlignment="Center" Foreground="{ThemeResource ApplicationForegroundThemeBrush}" />
                        <TextBlock Grid.Column="2" Text="&#xE26B;" FontFamily="Segoe UI Symbol" VerticalAlignment="Center" Opacity="0.5" />
                    </Grid>
                </Button>

                <Button Style="{StaticResource SettingsRowButtonStyle}"
                        Command="{Binding StickersCommand}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="32" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="&#xE170;" FontFamily="Segoe UI Symbol" VerticalAlignment="Center" Foreground="{ThemeResource SystemControlForegroundAccentBrush}" />
                        <TextBlock Grid.Column="1" Text="Stickers" VerticalAlignment="Center" Foreground="{ThemeResource ApplicationForegroundThemeBrush}" />
                        <TextBlock Grid.Column="2" Text="&#xE26B;" FontFamily="Segoe UI Symbol" VerticalAlignment="Center" Opacity="0.5" />
                    </Grid>
                </Button>

                <Button Style="{StaticResource SettingsRowButtonStyle}"
                        Command="{Binding DevicesCommand}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="32" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="&#xE1A6;" FontFamily="Segoe UI Symbol" VerticalAlignment="Center" Foreground="{ThemeResource SystemControlForegroundAccentBrush}" />
                        <TextBlock Grid.Column="1" Text="Devices" VerticalAlignment="Center" Foreground="{ThemeResource ApplicationForegroundThemeBrush}" />
                        <TextBlock Grid.Column="2" Text="&#xE26B;" FontFamily="Segoe UI Symbol" VerticalAlignment="Center" Opacity="0.5" />
                    </Grid>
                </Button>

                <Button Style="{StaticResource SettingsRowButtonStyle}"
                        Command="{Binding LanguageCommand}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="32" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="&#xE12B;" FontFamily="Segoe UI Symbol" VerticalAlignment="Center" Foreground="{ThemeResource SystemControlForegroundAccentBrush}" />
                        <TextBlock Grid.Column="1" Text="Language" VerticalAlignment="Center" Foreground="{ThemeResource ApplicationForegroundThemeBrush}" />
                        <TextBlock Grid.Column="2" Text="&#xE26B;" FontFamily="Segoe UI Symbol" VerticalAlignment="Center" Opacity="0.5" />
                    </Grid>
                </Button>

                <Button Style="{StaticResource SettingsRowButtonStyle}"
                        Command="{Binding ProxyCommand}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="32" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="&#xE17B;" FontFamily="Segoe UI Symbol" VerticalAlignment="Center" Foreground="{ThemeResource SystemControlForegroundAccentBrush}" />
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="Proxy and connection" Foreground="{ThemeResource ApplicationForegroundThemeBrush}" />
                            <TextBlock Text="{Binding ProxyStatus, Mode=OneWay}" FontSize="11" Opacity="0.6" TextTrimming="CharacterEllipsis" Margin="0,2,0,0" />
                        </StackPanel>
                        <TextBlock Grid.Column="2" Text="&#xE26B;" FontFamily="Segoe UI Symbol" VerticalAlignment="Center" Opacity="0.5" />
                    </Grid>
                </Button>

                <Button Style="{StaticResource SettingsRowButtonStyle}"
                        Command="{Binding AboutCommand}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="32" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="&#xE11B;" FontFamily="Segoe UI Symbol" VerticalAlignment="Center" Foreground="{ThemeResource SystemControlForegroundAccentBrush}" />
                        <TextBlock Grid.Column="1" Text="About" VerticalAlignment="Center" Foreground="{ThemeResource ApplicationForegroundThemeBrush}" />
                        <TextBlock Grid.Column="2" Text="&#xE26B;" FontFamily="Segoe UI Symbol" VerticalAlignment="Center" Opacity="0.5" />
                    </Grid>
                </Button>

                <Border Height="1"
                        Background="{ThemeResource SystemControlForegroundBaseLowBrush}"
                        Margin="16,8" />

                <Button HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Left"
                        Background="Transparent"
                        BorderThickness="0"
                        Padding="16,14"
                        Foreground="#FFFF5252"
                        Content="Log Out"
                        Command="{Binding LogoutCommand}" />

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
