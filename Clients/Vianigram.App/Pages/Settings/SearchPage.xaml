<Page
    x:Class="Vianigram.App.Pages.Settings.SearchPage"
    x:Name="PageRoot"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:Vianigram.App.Controls"
    xmlns:vm="using:Vianigram.App.ViewModels.Pages"
    mc:Ignorable="d"
    d:DataContext="{d:DesignInstance Type=vm:SearchPageViewModel, IsDesignTimeCreatable=True}"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Search"
                   FontSize="28"
                   FontWeight="SemiBold"
                   Foreground="{ThemeResource ApplicationForegroundThemeBrush}"
                   Margin="20,12,20,8" />

        <!-- Search input -->
        <TextBox Grid.Row="1"
                 PlaceholderText="Search chats, contacts, messages..."
                 Text="{Binding Query, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                 Margin="16,0,16,8" />

        <Grid Grid.Row="2">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>

                    <!-- Chats -->
                    <TextBlock Text="Chats"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="{ThemeResource SystemControlForegroundAccentBrush}"
                               Margin="16,8,16,4"
                               Visibility="{Binding ChatHitsVisibility, Mode=OneWay}" />
                    <ListView ItemsSource="{Binding ChatHits}"
                              SelectionMode="None"
                              IsItemClickEnabled="True"
                              ItemClick="OnChatHitClicked"
                              Visibility="{Binding ChatHitsVisibility, Mode=OneWay}">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Padding" Value="16,8,16,8" />
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="12" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <controls:AvatarCircle Grid.Column="0"
                                                           AvatarSize="40"
                                                           Initials="{Binding AvatarLetter}" />
                                    <StackPanel Grid.Column="2"
                                                VerticalAlignment="Center">
                                        <TextBlock Text="{Binding DisplayName}"
                                                   FontSize="15"
                                                   FontWeight="SemiBold"
                                                   Foreground="{ThemeResource ApplicationForegroundThemeBrush}"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{Binding Preview}"
                                                   FontSize="13"
                                                   Opacity="0.7"
                                                   TextTrimming="CharacterEllipsis"
                                                   Margin="0,2,0,0" />
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <!-- Contacts -->
                    <TextBlock Text="Contacts"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="{ThemeResource SystemControlForegroundAccentBrush}"
                               Margin="16,8,16,4"
                               Visibility="{Binding ContactHitsVisibility, Mode=OneWay}" />
                    <ListView ItemsSource="{Binding ContactHits}"
                              SelectionMode="None"
                              IsItemClickEnabled="True"
                              ItemClick="OnContactHitClicked"
                              Visibility="{Binding ContactHitsVisibility, Mode=OneWay}">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Padding" Value="16,8,16,8" />
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="12" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <controls:AvatarCircle Grid.Column="0"
                                                           AvatarSize="40"
                                                           Initials="{Binding AvatarLetter}" />
                                    <TextBlock Grid.Column="2"
                                               Text="{Binding DisplayName}"
                                               FontSize="15"
                                               FontWeight="SemiBold"
                                               Foreground="{ThemeResource ApplicationForegroundThemeBrush}"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <!-- Messages -->
                    <TextBlock Text="Messages"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="{ThemeResource SystemControlForegroundAccentBrush}"
                               Margin="16,8,16,4"
                               Visibility="{Binding MessageHitsVisibility, Mode=OneWay}" />
                    <ListView ItemsSource="{Binding MessageHits}"
                              SelectionMode="None"
                              IsItemClickEnabled="True"
                              ItemClick="OnMessageHitClicked"
                              Visibility="{Binding MessageHitsVisibility, Mode=OneWay}">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Padding" Value="16,8,16,8" />
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="12" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <controls:AvatarCircle Grid.Column="0"
                                                           AvatarSize="40"
                                                           Initials="{Binding AvatarLetter}" />
                                    <StackPanel Grid.Column="2"
                                                VerticalAlignment="Center">
                                        <TextBlock Text="{Binding DisplayName}"
                                                   FontSize="15"
                                                   FontWeight="SemiBold"
                                                   Foreground="{ThemeResource ApplicationForegroundThemeBrush}"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{Binding Preview}"
                                                   FontSize="13"
                                                   Opacity="0.7"
                                                   TextTrimming="CharacterEllipsis"
                                                   Margin="0,2,0,0" />
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <!-- No-results state -->
                    <TextBlock Text="No results"
                               FontSize="14"
                               Opacity="0.6"
                               Foreground="{ThemeResource ApplicationForegroundThemeBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,40,0,0"
                               Visibility="{Binding NoResultsVisibility, Mode=OneWay}" />

                </StackPanel>
            </ScrollViewer>

            <ProgressRing IsActive="{Binding IsSearching, Mode=OneWay}"
                          Width="32" Height="32"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Top"
                          Margin="0,8,0,0"
                          Visibility="{Binding SearchingVisibility, Mode=OneWay}" />
        </Grid>
    </Grid>
</Page>
