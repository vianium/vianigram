<Page
    x:Class="Vianigram.App.Pages.Profile.GroupInfoPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Vianigram.App.Controls"
    xmlns:vm="using:Vianigram.App.ViewModels.Pages"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    d:DataContext="{d:DesignInstance Type=vm:GroupInfoPageViewModel, IsDesignTimeCreatable=True}"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0"
              Background="{ThemeResource SystemControlBackgroundChromeMediumBrush}"
              Height="56">
            <TextBlock Text="Group Info"
                       FontSize="20"
                       FontWeight="SemiBold"
                       Foreground="{ThemeResource ApplicationForegroundThemeBrush}"
                       VerticalAlignment="Center"
                       Margin="20,0,0,0" />
        </Grid>

        <ScrollViewer Grid.Row="1">
            <StackPanel>

                <!-- Group avatar / title / member count -->
                <StackPanel HorizontalAlignment="Center" Margin="0,24,0,16">
                    <controls:AvatarCircle AvatarSize="96"
                                           Initials="{Binding Title}"
                                           HorizontalAlignment="Center" />

                    <TextBlock Text="{Binding Title}"
                               FontSize="24"
                               FontWeight="SemiBold"
                               Foreground="{ThemeResource ApplicationForegroundThemeBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,12,0,0" />

                    <TextBlock Text="{Binding MemberCountLabel}"
                               FontSize="14"
                               Opacity="0.6"
                               Foreground="{ThemeResource ApplicationForegroundThemeBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,4,0,0" />
                </StackPanel>

                <!-- Description -->
                <Border Background="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}"
                        Margin="0,8,0,0"
                        Padding="16,12">
                    <StackPanel>
                        <TextBlock Text="Description"
                                   FontSize="13"
                                   Foreground="{ThemeResource SystemControlHighlightAccentBrush}" />
                        <TextBlock Text="{Binding Description}"
                                   FontSize="15"
                                   Foreground="{ThemeResource ApplicationForegroundThemeBrush}"
                                   Margin="0,2,0,0"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <!-- Action buttons row -->
                <Grid Margin="16,12,16,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0"
                            Content="Add Members"
                            Command="{Binding AddMembersCommand}"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center"
                            Padding="8,12"
                            Background="{ThemeResource SystemControlHighlightAccentBrush}"
                            Foreground="{ThemeResource ApplicationForegroundThemeBrush}" />
                    <Button Grid.Column="2"
                            Content="Edit"
                            Command="{Binding EditCommand}"
                            IsEnabled="{Binding CanEdit}"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center"
                            Padding="8,12"
                            Background="{ThemeResource SystemControlBackgroundChromeMediumBrush}"
                            Foreground="{ThemeResource ApplicationForegroundThemeBrush}" />
                </Grid>

                <Button Content="{Binding MuteButtonLabel}"
                        Command="{Binding ToggleMuteCommand}"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Center"
                        Margin="16,4"
                        Padding="16,12"
                        Background="{ThemeResource SystemControlBackgroundChromeMediumBrush}"
                        Foreground="{ThemeResource ApplicationForegroundThemeBrush}" />

                <!-- Members header -->
                <TextBlock Text="Members"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Foreground="{ThemeResource SystemControlHighlightAccentBrush}"
                           Margin="16,16,16,4" />

                <!-- Members list -->
                <ListView ItemsSource="{Binding Members}"
                          SelectionMode="None"
                          IsItemClickEnabled="False">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="Margin" Value="0" />
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid Height="60" Margin="12,8,12,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="44" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <controls:AvatarCircle Grid.Column="0"
                                                       AvatarSize="40"
                                                       Initials="{Binding AvatarLetter}"
                                                       VerticalAlignment="Center" />
                                <TextBlock Grid.Column="2"
                                           Text="{Binding DisplayName}"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           Foreground="{ThemeResource ApplicationForegroundThemeBrush}"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis" />
                                <TextBlock Grid.Column="3"
                                           Text="{Binding AdminLabel}"
                                           FontSize="12"
                                           Foreground="{ThemeResource SystemControlHighlightAccentBrush}"
                                           VerticalAlignment="Center"
                                           Margin="8,0,0,0" />
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <!-- Leave -->
                <Button Content="Leave Group"
                        Command="{Binding LeaveCommand}"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Center"
                        Margin="16,16,16,24"
                        Padding="16,12"
                        Background="{ThemeResource SystemControlBackgroundChromeMediumBrush}"
                        Foreground="Red" />

                <TextBlock Text="{Binding ErrorMessage}"
                           Foreground="Red"
                           TextWrapping="Wrap"
                           Margin="20,4,20,12"
                           Visibility="{Binding HasError}" />
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
