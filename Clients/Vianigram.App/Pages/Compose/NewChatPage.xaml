<Page
    x:Class="Vianigram.App.Pages.Compose.NewChatPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Vianigram.App.Controls"
    xmlns:conv="using:Vianigram.App.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:Vianigram.App.ViewModels.Pages"
    mc:Ignorable="d"
    d:DataContext="{d:DesignInstance Type=vm:NewChatPageViewModel, IsDesignTimeCreatable=True}"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Page.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibility" />
    </Page.Resources>

    <Grid>
        <!-- Step 1: contacts -->
        <Grid Visibility="{Binding IsContactsStep, Converter={StaticResource BoolToVisibility}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Text="New chat"
                       FontSize="28"
                       FontWeight="SemiBold"
                       Margin="20,12,20,8" />

            <!-- Chat type selector -->
            <StackPanel Grid.Row="1"
                        Orientation="Horizontal"
                        Margin="20,0,20,8">
                <RadioButton Content="Group"
                             GroupName="ChatType"
                             IsChecked="{Binding IsGroup, Mode=TwoWay}"
                             Margin="0,0,12,0" />
                <RadioButton Content="Secret Chat"
                             GroupName="ChatType"
                             IsChecked="{Binding IsSecret, Mode=TwoWay}"
                             Margin="0,0,12,0" />
                <RadioButton Content="Channel"
                             GroupName="ChatType"
                             IsChecked="{Binding IsChannel, Mode=TwoWay}" />
            </StackPanel>

            <!-- Search box -->
            <TextBox Grid.Row="2"
                     Text="{Binding SearchQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     PlaceholderText="Search contacts"
                     Margin="20,4,20,4" />

            <!-- Status -->
            <TextBlock Grid.Row="3"
                       Text="{Binding StatusText}"
                       FontSize="13"
                       Opacity="0.7"
                       Margin="20,4,20,4" />

            <!-- Contacts list -->
            <ListView Grid.Row="4"
                      x:Name="ContactsList"
                      ItemsSource="{Binding Contacts}"
                      SelectionMode="Multiple"
                      IsItemClickEnabled="True"
                      ItemClick="OnContactClicked">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="Padding" Value="16,8,16,8" />
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <controls:AvatarCircle Grid.Column="0"
                                                   AvatarSize="40"
                                                   Initials="{Binding AvatarLetter}"
                                                   ColorSeed="{Binding AvatarColorSeed}"
                                                   VerticalAlignment="Center" />
                            <TextBlock Grid.Column="2"
                                       Text="{Binding DisplayName}"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"
                                       Foreground="{ThemeResource ApplicationForegroundThemeBrush}" />
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <!-- Next button -->
            <Button Grid.Row="5"
                    Content="Next"
                    Command="{Binding NextCommand}"
                    HorizontalAlignment="Stretch"
                    Margin="20,8,20,16" />
        </Grid>

        <!-- Step 2: meta -->
        <Grid Visibility="{Binding IsMetaStep, Converter={StaticResource BoolToVisibility}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Text="Group details"
                       FontSize="28"
                       FontWeight="SemiBold"
                       Margin="20,12,20,8" />

            <Grid Grid.Row="1" Margin="20,8,20,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <controls:AvatarCircle Grid.Column="0"
                                       AvatarSize="56"
                                       Initials="?"
                                       VerticalAlignment="Center" />
                <TextBox Grid.Column="2"
                         Text="{Binding GroupTitle, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         PlaceholderText="Group name"
                         VerticalAlignment="Center" />
            </Grid>

            <TextBlock Grid.Row="2"
                       Text="{Binding StatusText}"
                       FontSize="13"
                       Opacity="0.7"
                       Margin="20,4,20,4" />

            <ListView Grid.Row="3"
                      ItemsSource="{Binding Selected}"
                      SelectionMode="None">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="Padding" Value="16,4,16,4" />
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <controls:AvatarCircle Grid.Column="0"
                                                   AvatarSize="36"
                                                   Initials="{Binding AvatarLetter}"
                                                   ColorSeed="{Binding AvatarColorSeed}"
                                                   VerticalAlignment="Center" />
                            <TextBlock Grid.Column="2"
                                       Text="{Binding DisplayName}"
                                       FontSize="14"
                                       VerticalAlignment="Center"
                                       Foreground="{ThemeResource ApplicationForegroundThemeBrush}" />
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <TextBlock Grid.Row="4"
                       Text="{Binding ErrorMessage}"
                       Foreground="Red"
                       TextWrapping="Wrap"
                       Margin="20,4,20,4" />

            <Grid Grid.Row="5" Margin="20,8,20,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0"
                        Content="Back"
                        Command="{Binding BackCommand}"
                        HorizontalAlignment="Stretch"
                        Margin="0,0,4,0" />
                <Button Grid.Column="1"
                        Content="Create"
                        Command="{Binding CreateCommand}"
                        HorizontalAlignment="Stretch"
                        Margin="4,0,0,0" />
            </Grid>
        </Grid>
    </Grid>
</Page>
