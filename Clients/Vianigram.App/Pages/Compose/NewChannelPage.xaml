<Page
    x:Class="Vianigram.App.Pages.Compose.NewChannelPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="using:Vianigram.App.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:Vianigram.App.ViewModels.Pages"
    mc:Ignorable="d"
    d:DataContext="{d:DesignInstance Type=vm:NewChannelPageViewModel, IsDesignTimeCreatable=True}"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Page.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibility" />
    </Page.Resources>

    <Grid>
        <ScrollViewer>
            <StackPanel Margin="20,16,20,16">
                <TextBlock Text="New channel"
                           FontSize="28"
                           FontWeight="SemiBold"
                           Margin="0,0,0,12" />

                <TextBlock Text="Channel name"
                           FontSize="14"
                           Opacity="0.7"
                           Margin="0,0,0,4" />
                <TextBox Text="{Binding Title, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         PlaceholderText="Enter channel name"
                         Margin="0,0,0,12" />

                <TextBlock Text="Description"
                           FontSize="14"
                           Opacity="0.7"
                           Margin="0,0,0,4" />
                <TextBox Text="{Binding Description, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         PlaceholderText="Optional"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         Height="100"
                         Margin="0,0,0,12" />

                <Grid Margin="0,4,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="Public channel"
                                   FontSize="16"
                                   Foreground="{ThemeResource ApplicationForegroundThemeBrush}" />
                        <TextBlock Text="Public channels appear in search."
                                   FontSize="12"
                                   Opacity="0.6"
                                   Margin="0,2,0,0" />
                    </StackPanel>
                    <ToggleSwitch Grid.Column="1"
                                  IsOn="{Binding IsPublic, Mode=TwoWay}"
                                  VerticalAlignment="Center" />
                </Grid>

                <!-- Username (public only) -->
                <StackPanel Visibility="{Binding IsPublic, Converter={StaticResource BoolToVisibility}}">
                    <TextBlock Text="Username"
                               FontSize="14"
                               Opacity="0.7"
                               Margin="0,0,0,4" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0"
                                 x:Name="UsernameBox"
                                 Text="{Binding Username, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 PlaceholderText="my_channel"
                                 TextChanged="OnUsernameTextChanged" />
                        <ProgressRing Grid.Column="1"
                                      IsActive="{Binding IsCheckingUsername}"
                                      Width="20"
                                      Height="20"
                                      Margin="8,0,0,0"
                                      VerticalAlignment="Center" />
                    </Grid>

                    <TextBlock Text="Username is available."
                               Foreground="Green"
                               FontSize="12"
                               Margin="0,4,0,0"
                               Visibility="{Binding UsernameAvailable, Converter={StaticResource BoolToVisibility}}" />

                    <TextBlock Text="{Binding UsernameError}"
                               Foreground="Red"
                               FontSize="12"
                               TextWrapping="Wrap"
                               Margin="0,4,0,0"
                               Visibility="{Binding HasUsernameError, Converter={StaticResource BoolToVisibility}}" />
                </StackPanel>

                <Button Content="Create channel"
                        Command="{Binding CreateCommand}"
                        HorizontalAlignment="Stretch"
                        Margin="0,16,0,8" />

                <ProgressRing IsActive="{Binding IsBusy}"
                              Width="24"
                              Height="24"
                              HorizontalAlignment="Center"
                              Margin="0,8,0,0" />

                <TextBlock Text="{Binding StatusText}"
                           FontSize="13"
                           Opacity="0.7"
                           HorizontalAlignment="Center"
                           Margin="0,8,0,0" />

                <TextBlock Text="{Binding ErrorMessage}"
                           Foreground="Red"
                           TextWrapping="Wrap"
                           Margin="0,8,0,0"
                           Visibility="{Binding HasError, Converter={StaticResource BoolToVisibility}}" />
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
