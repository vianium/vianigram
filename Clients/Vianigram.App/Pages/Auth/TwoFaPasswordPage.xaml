<Page
    x:Class="Vianigram.App.Pages.Auth.TwoFaPasswordPage"
    x:Name="RootPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:conv="using:Vianigram.App.Converters"
    xmlns:layout="using:Vianigram.App.Controls.Layout"
    xmlns:vm="using:Vianigram.App.ViewModels.Pages"
    mc:Ignorable="d"
    d:DataContext="{d:DesignInstance Type=vm:TwoFaPasswordPageViewModel, IsDesignTimeCreatable=True}"
    Background="{ThemeResource VgBgBrush}">

    <Page.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibility" />

        <Style x:Key="TwoFaPasswordBoxStyle" TargetType="PasswordBox">
            <Setter Property="FontFamily" Value="{StaticResource VgFont}" />
            <Setter Property="FontSize" Value="20" />
            <Setter Property="FontWeight" Value="Normal" />
            <Setter Property="Foreground" Value="{ThemeResource VgFgBrush}" />
            <Setter Property="Background" Value="{ThemeResource VgBgBrush}" />
            <Setter Property="BorderBrush" Value="{ThemeResource VgFg3Brush}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="Padding" Value="0,4,0,8" />
        </Style>

        <Style x:Key="TwoFaLinkButtonStyle" TargetType="Button">
            <Setter Property="FontFamily" Value="{StaticResource VgFont}" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Foreground" Value="{ThemeResource VgAccentBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0,8" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid x:Name="Root" Background="Transparent">
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal" />
                                    <VisualState x:Name="PointerOver" />
                                    <VisualState x:Name="Pressed">
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="Root"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="0.55"
                                                             Duration="0:0:0.08" />
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Disabled">
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="Root"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="0.35"
                                                             Duration="0" />
                                        </Storyboard>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                            <ContentPresenter Content="{TemplateBinding Content}"
                                              Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Page.BottomAppBar>
        <CommandBar DataContext="{Binding DataContext, ElementName=RootPage}">
            <AppBarButton x:Uid="CommonSubmitAppBar"
                          Label="submit"
                          Icon="Accept"
                          Command="{Binding SubmitCommand}" />
        </CommandBar>
    </Page.BottomAppBar>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <layout:AppHeader x:Name="HeaderControl" Grid.Row="0" />

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollMode="Disabled">
            <StackPanel Margin="24,14,24,0"
                        MaxWidth="500"
                        HorizontalAlignment="Stretch">
                <TextBlock x:Uid="TwoFaPasswordDescription"
                           Text="this account is protected by two-step verification. enter your cloud password to continue."
                           Style="{StaticResource VgBodyStyle}"
                           Foreground="{ThemeResource VgFg2Brush}"
                           TextWrapping="Wrap"
                           Margin="0,0,0,38" />

                <PasswordBox x:Name="PasswordInput"
                             x:Uid="TwoFaPasswordInput"
                             Style="{StaticResource TwoFaPasswordBoxStyle}"
                             PlaceholderText="password"
                             PasswordChanged="OnPasswordChanged"
                             KeyDown="OnPasswordKeyDown" />

                <TextBlock Text="{Binding PasswordHintText}"
                           Style="{StaticResource VgCaptionStyle}"
                           Foreground="{ThemeResource VgFg3Brush}"
                           Visibility="{Binding HasPasswordHint, Converter={StaticResource BoolToVisibility}}"
                           Margin="0,8,0,28" />

                <Button x:Uid="TwoFaPasswordForgotButton"
                        Content="forgot password?"
                        Command="{Binding ForgotPasswordCommand}"
                        Style="{StaticResource TwoFaLinkButtonStyle}"
                        HorizontalAlignment="Left"
                        Margin="0,0,0,12" />

                <layout:ProgressDots IsActive="{Binding IsBusy}" Margin="0,4,0,0" />

                <TextBlock Text="{Binding ErrorMessage}"
                           Style="{StaticResource VgCaptionStyle}"
                           Foreground="{ThemeResource VgDangerBrush}"
                           TextWrapping="Wrap"
                           Visibility="{Binding HasError, Converter={StaticResource BoolToVisibility}}"
                           Margin="0,16,0,0" />
            </StackPanel>
        </ScrollViewer>

    </Grid>
</Page>
