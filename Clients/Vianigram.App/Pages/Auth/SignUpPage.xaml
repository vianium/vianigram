<Page
    x:Class="Vianigram.App.Pages.Auth.SignUpPage"
    x:Name="RootPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:conv="using:Vianigram.App.Converters"
    xmlns:layout="using:Vianigram.App.Controls.Layout"
    xmlns:vm="using:Vianigram.App.ViewModels.Pages"
    mc:Ignorable="d"
    d:DataContext="{d:DesignInstance Type=vm:SignUpPageViewModel, IsDesignTimeCreatable=True}"
    Background="{ThemeResource VgBgBrush}">

    <Page.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibility" />
    </Page.Resources>

    <Page.BottomAppBar>
        <CommandBar DataContext="{Binding DataContext, ElementName=RootPage}">
            <AppBarButton x:Uid="CommonSubmitAppBar"
                          Label="submit"
                          Icon="Accept"
                          Command="{Binding SubmitCommand}" />
        </CommandBar>
    </Page.BottomAppBar>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <layout:AppHeader x:Name="HeaderControl" Grid.Row="0" />

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollMode="Disabled">
            <StackPanel Margin="24,14,24,0"
                        MaxWidth="500"
                        HorizontalAlignment="Stretch">
                <TextBlock x:Uid="SignUpDescription"
                           Text="this phone number is new to telegram. enter your name to create the account."
                           Style="{StaticResource VgBodyStyle}"
                           Foreground="{ThemeResource VgFg2Brush}"
                           TextWrapping="Wrap"
                           Margin="0,0,0,30" />

                <TextBox x:Name="FirstNameInput"
                         x:Uid="SignUpFirstNameInput"
                         Style="{StaticResource VgFieldUnderlineStyle}"
                         Text="{Binding FirstName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         PlaceholderText="first name"
                         KeyDown="OnInputKeyDown"
                         Margin="0,0,0,18" />

                <TextBox x:Name="LastNameInput"
                         x:Uid="SignUpLastNameInput"
                         Style="{StaticResource VgFieldUnderlineStyle}"
                         Text="{Binding LastName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         PlaceholderText="last name"
                         KeyDown="OnInputKeyDown"
                         Margin="0,0,0,24" />

                <layout:ProgressDots IsActive="{Binding IsBusy}" Margin="0,4,0,0" />

                <TextBlock Text="{Binding ErrorMessage}"
                           Style="{StaticResource VgCaptionStyle}"
                           Foreground="{ThemeResource VgDangerBrush}"
                           TextWrapping="Wrap"
                           Visibility="{Binding HasError, Converter={StaticResource BoolToVisibility}}"
                           Margin="0,16,0,0" />
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
