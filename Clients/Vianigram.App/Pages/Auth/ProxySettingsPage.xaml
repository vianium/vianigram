<Page
    x:Class="Vianigram.App.Pages.Auth.ProxySettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:Vianigram.App.ViewModels.Pages"
    mc:Ignorable="d"
    d:DataContext="{d:DesignInstance Type=vm:ProxySettingsPageViewModel, IsDesignTimeCreatable=True}"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{ThemeResource SystemControlBackgroundChromeMediumBrush}"
                Padding="16,14">
            <TextBlock Text="MTProxy connection"
                       FontSize="18"
                       FontWeight="SemiBold"
                       Foreground="{ThemeResource ApplicationForegroundThemeBrush}"
                       VerticalAlignment="Center" />
        </Border>

        <ScrollViewer Grid.Row="1">
            <StackPanel Margin="16,12,16,0">

                <!-- Enable / disable -->
                <Border Padding="0,0,0,4">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Use MTProxy"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       Foreground="{ThemeResource ApplicationForegroundThemeBrush}" />
                            <TextBlock Text="Route all MTProto traffic through the proxy below."
                                       FontSize="12"
                                       Opacity="0.7"
                                       TextWrapping="Wrap"
                                       Margin="0,2,0,0" />
                        </StackPanel>
                        <ToggleSwitch Grid.Column="1"
                                      IsOn="{Binding Enabled, Mode=TwoWay}"
                                      OffContent=""
                                      OnContent="" />
                    </Grid>
                </Border>

                <Border Height="1"
                        Background="{ThemeResource SystemControlForegroundBaseLowBrush}"
                        Margin="0,8,0,8" />

                <TextBlock Text="Proxy host"
                           Foreground="{ThemeResource ApplicationForegroundThemeBrush}"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Margin="0,0,0,6" />
                <TextBox Text="{Binding Host, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         PlaceholderText="proxy.example.com or 1.2.3.4"
                         InputScope="Url"
                         Margin="0,0,0,12" />

                <TextBlock Text="Port"
                           Foreground="{ThemeResource ApplicationForegroundThemeBrush}"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Margin="0,0,0,6" />
                <TextBox Text="{Binding PortText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         PlaceholderText="443"
                         InputScope="Number"
                         Margin="0,0,0,12" />

                <TextBlock Text="Secret"
                           Foreground="{ThemeResource ApplicationForegroundThemeBrush}"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Margin="0,0,0,6" />
                <TextBox Text="{Binding SecretInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         PlaceholderText="Paste a tg://proxy URL or the secret string"
                         TextWrapping="Wrap"
                         AcceptsReturn="False"
                         Margin="0,0,0,4" />
                <TextBlock Text="{Binding ParsedSecretSummary, Mode=OneWay}"
                           FontSize="12"
                           Opacity="0.75"
                           TextWrapping="Wrap"
                           Margin="0,0,0,12" />

                <TextBlock Text="Label (optional)"
                           Foreground="{ThemeResource ApplicationForegroundThemeBrush}"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Margin="0,0,0,6" />
                <TextBox Text="{Binding Label, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         PlaceholderText="e.g. Work, Home, Travel"
                         Margin="0,0,0,12" />

                <TextBlock Text="{Binding TestResult, Mode=OneWay}"
                           Foreground="{ThemeResource ApplicationForegroundThemeBrush}"
                           Opacity="0.85"
                           FontSize="13"
                           TextWrapping="Wrap"
                           Margin="0,8,0,0" />

                <ProgressRing IsActive="{Binding IsTesting, Mode=OneWay}"
                              Width="20"
                              Height="20"
                              HorizontalAlignment="Left"
                              Margin="0,8,0,8" />

                <Button Content="Clear and disable"
                        Command="{Binding ClearCommand}"
                        HorizontalAlignment="Stretch"
                        Background="Transparent"
                        BorderThickness="0"
                        Foreground="#FFFF5252"
                        Padding="16,12"
                        Margin="0,16,0,0" />

            </StackPanel>
        </ScrollViewer>

        <Grid Grid.Row="2" Margin="16,8,16,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                    Content="Test"
                    Command="{Binding TestCommand}"
                    HorizontalAlignment="Stretch"
                    Padding="16,12" />

            <Button Grid.Column="2"
                    Content="Save"
                    Command="{Binding SaveCommand}"
                    Background="{ThemeResource SystemControlBackgroundAccentBrush}"
                    Foreground="{ThemeResource ApplicationForegroundThemeBrush}"
                    HorizontalAlignment="Stretch"
                    Padding="16,12" />
        </Grid>
    </Grid>
</Page>
