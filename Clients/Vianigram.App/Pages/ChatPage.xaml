<Page
    x:Class="Vianigram.App.Pages.ChatPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:bubbles="using:Vianigram.App.Controls.Bubbles"
    xmlns:controls="using:Vianigram.App.Controls"
    mc:Ignorable="d"
    Background="{ThemeResource VgBgBrush}">

    <Page.Resources>
        <!-- Text bubble (default / fallback). Wraps the existing
             MessageBubble UserControl with an optional author chip rendered
             above when the row is in a group / channel and the sender is
             the first of a consecutive run (Telegram-style stacked bubbles). -->
        <DataTemplate x:Key="TextBubbleTemplate">
            <StackPanel>
                <TextBlock Text="{Binding AuthorLabel}"
                           Visibility="{Binding ShowAuthor, Converter={StaticResource BoolToVisibility}}"
                           Margin="14,6,86,0"
                           FontFamily="{StaticResource VgFont}"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="{ThemeResource VgAccentBrush}" />
                <bubbles:MessageBubble MessageText="{Binding Text}"
                                       TextEntities="{Binding TextEntities}"
                                       ReactionSummary="{Binding ReactionSummary}"
                                       Timestamp="{Binding TimeLabel}"
                                       IsOutgoing="{Binding IsOutgoing}"
                                       StatusGlyph="{Binding StatusLabel}"
                                       HasReply="{Binding HasReply}"
                                       ReplyAuthor="{Binding ReplyAuthorLabel}"
                                       ReplyPreview="{Binding ReplyPreviewText}" />
            </StackPanel>
        </DataTemplate>

        <!-- Photo: thumbnail placeholder + badge + caption -->
        <DataTemplate x:Key="PhotoBubbleTemplate">
            <StackPanel>
                <TextBlock Text="{Binding AuthorLabel}"
                           Visibility="{Binding ShowAuthor, Converter={StaticResource BoolToVisibility}}"
                           Margin="14,6,86,0"
                           FontFamily="{StaticResource VgFont}"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="{ThemeResource VgAccentBrush}" />
                <bubbles:PhotoBubble ImageSource="{Binding MediaSource}"
                                     ImagePath="{Binding MediaFullPath}"
                                     OpenPath="{Binding MediaFullPath}"
                                     PreviewBytes="{Binding MediaPreviewBytes}"
                                     Caption="{Binding MediaCaption}"
                                     CaptionEntities="{Binding CaptionEntities}"
                                     IsOutgoing="{Binding IsOutgoing}"
                                     PhotoWidth="{Binding MediaWidth}"
                                     PhotoHeight="{Binding MediaHeight}"
                                     IsLoading="{Binding IsMediaLoading}"
                                     HasFailed="{Binding HasMediaFailed}"
                                     DownloadProgress="{Binding MediaDownloadProgress}"
                                     DownloadRequested="OnMediaDownloadRequested"
                                     OpenRequested="OnMediaOpenRequested" />
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="10,0,12,4">
                    <TextBlock Text="{Binding TimeLabel}" FontSize="11" Foreground="#B3FFFFFF" />
                    <TextBlock Text="{Binding StatusLabel}" FontSize="11" Margin="5,0,0,0" Foreground="#D2FFFFFF" />
                </StackPanel>
            </StackPanel>
        </DataTemplate>

        <!-- Video / animation: show a thumbnail or placeholder, then open the
             downloaded media in the full-screen native viewer. -->
        <DataTemplate x:Key="VideoBubbleTemplate">
            <StackPanel>
                <TextBlock Text="{Binding AuthorLabel}"
                           Visibility="{Binding ShowAuthor, Converter={StaticResource BoolToVisibility}}"
                           Margin="14,6,86,0"
                           FontFamily="{StaticResource VgFont}"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="{ThemeResource VgAccentBrush}" />
                <bubbles:PhotoBubble ImageSource="{Binding MediaSource}"
                                     OpenPath="{Binding MediaFullPath}"
                                     PreviewBytes="{Binding MediaPreviewBytes}"
                                     Caption="{Binding MediaCaption}"
                                     CaptionEntities="{Binding CaptionEntities}"
                                     IsOutgoing="{Binding IsOutgoing}"
                                     PhotoWidth="{Binding MediaWidth}"
                                     PhotoHeight="{Binding MediaHeight}"
                                     IsLoading="{Binding IsMediaLoading}"
                                     HasFailed="{Binding HasMediaFailed}"
                                     DownloadProgress="{Binding MediaDownloadProgress}"
                                     OverlayText="{Binding MediaTypeBadge}"
                                     DownloadRequested="OnMediaDownloadRequested"
                                     OpenRequested="OnMediaOpenRequested" />
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="10,0,12,4">
                    <TextBlock Text="{Binding TimeLabel}" FontSize="11" Foreground="#B3FFFFFF" />
                    <TextBlock Text="{Binding StatusLabel}" FontSize="11" Margin="5,0,0,0" Foreground="#D2FFFFFF" />
                </StackPanel>
            </StackPanel>
        </DataTemplate>

        <!-- Voice: mic icon + waveform + duration -->
        <DataTemplate x:Key="VoiceBubbleTemplate">
            <StackPanel>
                <TextBlock Text="{Binding AuthorLabel}"
                           Visibility="{Binding ShowAuthor, Converter={StaticResource BoolToVisibility}}"
                           Margin="14,6,86,0"
                           FontFamily="{StaticResource VgFont}"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="{ThemeResource VgAccentBrush}" />
                <bubbles:VoiceBubble AudioSource="{Binding AudioSource}"
                                     WaveformData="{Binding WaveformData}"
                                     DurationSeconds="{Binding DurationSeconds}"
                                     ElapsedSeconds="{Binding ElapsedSeconds}"
                                     IsPlaying="{Binding IsPlaying}"
                                     IsDownloading="{Binding IsDownloading}"
                                     HasFailed="{Binding HasDownloadFailed}"
                                     DownloadProgress="{Binding DownloadProgress}"
                                     IsOutgoing="{Binding IsOutgoing}"
                                     DownloadRequested="OnAudioDownloadRequested" />
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="10,0,12,4">
                    <TextBlock Text="{Binding TimeLabel}" FontSize="11" Foreground="#B3FFFFFF" />
                    <TextBlock Text="{Binding StatusLabel}" FontSize="11" Margin="5,0,0,0" Foreground="#D2FFFFFF" />
                </StackPanel>
            </StackPanel>
        </DataTemplate>

        <!-- Audio (music): note icon + title + performer + duration -->
        <DataTemplate x:Key="AudioBubbleTemplate">
            <StackPanel>
                <TextBlock Text="{Binding AuthorLabel}"
                           Visibility="{Binding ShowAuthor, Converter={StaticResource BoolToVisibility}}"
                           Margin="14,6,86,0"
                           FontFamily="{StaticResource VgFont}"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="{ThemeResource VgAccentBrush}" />
                <Border MaxWidth="304"
                        Margin="8,2,8,0"
                        Padding="12,8"
                        CornerRadius="2"
                        Background="{ThemeResource VgSurfaceBrush}">
                    <StackPanel>
                        <TextBlock Text="{Binding AudioTitle}"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="White"
                                   TextTrimming="CharacterEllipsis" />
                        <TextBlock Text="{Binding AudioPerformer}"
                                   FontSize="12"
                                   Foreground="#B3FFFFFF"
                                   TextTrimming="CharacterEllipsis"
                                   Visibility="{Binding AudioPerformer, Converter={StaticResource StringNotEmptyToVisibility}}" />
                    </StackPanel>
                </Border>
                <bubbles:VoiceBubble AudioSource="{Binding AudioSource}"
                                     WaveformData="{Binding WaveformData}"
                                     DurationSeconds="{Binding DurationSeconds}"
                                     ElapsedSeconds="{Binding ElapsedSeconds}"
                                     IsPlaying="{Binding IsPlaying}"
                                     IsDownloading="{Binding IsDownloading}"
                                     HasFailed="{Binding HasDownloadFailed}"
                                     DownloadProgress="{Binding DownloadProgress}"
                                     IsOutgoing="{Binding IsOutgoing}"
                                     DownloadRequested="OnAudioDownloadRequested" />
                <TextBlock Text="{Binding MediaCaption}"
                           TextWrapping="Wrap"
                           FontSize="14"
                           Margin="14,0,14,4"
                           Foreground="White"
                           Visibility="{Binding MediaCaption, Converter={StaticResource StringNotEmptyToVisibility}}" />
            </StackPanel>
        </DataTemplate>

        <!-- Document: icon circle + filename + size -->
        <DataTemplate x:Key="DocumentBubbleTemplate">
            <StackPanel>
                <TextBlock Text="{Binding AuthorLabel}"
                           Visibility="{Binding ShowAuthor, Converter={StaticResource BoolToVisibility}}"
                           Margin="14,6,86,0"
                           FontFamily="{StaticResource VgFont}"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="{ThemeResource VgAccentBrush}" />
                <bubbles:DocumentBubble FileName="{Binding FileName}"
                                        FileSize="{Binding FileSizeLabel}"
                                        MimeType="{Binding FileMime}"
                                        FilePath="{Binding FilePath}"
                                        Caption="{Binding MediaCaption}"
                                        CaptionEntities="{Binding CaptionEntities}"
                                        TotalBytes="{Binding TotalBytes}"
                                        DownloadedBytes="{Binding DownloadedBytes}"
                                        IsDownloaded="{Binding IsDownloaded}"
                                        IsDownloading="{Binding IsDownloading}"
                                        HasFailed="{Binding HasDownloadFailed}"
                                        DownloadProgress="{Binding DownloadProgress}"
                                        IsOutgoing="{Binding IsOutgoing}"
                                        DownloadRequested="OnDocumentDownloadRequested"
                                        OpenRequested="OnDocumentOpenRequested" />
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="10,0,12,4">
                    <TextBlock Text="{Binding TimeLabel}" FontSize="11" Foreground="#B3FFFFFF" />
                    <TextBlock Text="{Binding StatusLabel}" FontSize="11" Margin="5,0,0,0" Foreground="#D2FFFFFF" />
                </StackPanel>
            </StackPanel>
        </DataTemplate>

        <!-- Sticker -->
        <DataTemplate x:Key="StickerBubbleTemplate">
            <Grid HorizontalAlignment="Stretch" Margin="2,4,86,4">
                <StackPanel HorizontalAlignment="Left" MaxWidth="188">
                    <Grid Width="168" Height="168">
                        <Image Source="{Binding StickerImageSource}"
                               Stretch="Uniform"
                               MaxWidth="168"
                               MaxHeight="168"
                               Visibility="{Binding StickerImageSource, Converter={StaticResource StringNotEmptyToVisibility}}" />
                        <TextBlock Text="{Binding StickerEmoji}"
                                   FontSize="76"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="White"
                                   Visibility="{Binding StickerImageSource, Converter={StaticResource StringNotEmptyToVisibility}, ConverterParameter=Invert}" />
                    </Grid>
                    <TextBlock Text="{Binding StickerEmoji}"
                               HorizontalAlignment="Center"
                               FontSize="13"
                               Foreground="#99FFFFFF"
                               Visibility="{Binding StickerImageSource, Converter={StaticResource StringNotEmptyToVisibility}}" />
                    <TextBlock Text="{Binding TimeLabel}"
                               FontSize="11"
                               Foreground="#80FFFFFF"
                               HorizontalAlignment="Center"
                               Margin="0,4,0,0" />
                </StackPanel>
            </Grid>
        </DataTemplate>

        <!-- Contact: initials + name + phone action -->
        <DataTemplate x:Key="ContactBubbleTemplate">
            <Grid HorizontalAlignment="Stretch" Margin="2,3,86,3">
                <Border Background="{ThemeResource VgSurfaceBrush}"
                        CornerRadius="2"
                        MaxWidth="292"
                        HorizontalAlignment="Left"
                        Padding="12,10,14,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="44" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Ellipse Grid.Column="0" Width="40" Height="40" Fill="{ThemeResource VgAccentBrush}" />
                        <TextBlock Grid.Column="0"
                                   Text="{Binding ContactInitials}"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="White" />
                        <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="{Binding ContactName}" FontSize="14" FontWeight="SemiBold" Foreground="White" TextTrimming="CharacterEllipsis" />
                            <HyperlinkButton NavigateUri="{Binding ContactPhoneUri}"
                                             Padding="0"
                                             HorizontalAlignment="Left"
                                             Visibility="{Binding ContactPhone, Converter={StaticResource StringNotEmptyToVisibility}}">
                                <TextBlock Text="{Binding ContactPhone}" FontSize="12" Foreground="#B3FFFFFF" />
                            </HyperlinkButton>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </DataTemplate>

        <!-- Location -->
        <DataTemplate x:Key="LocationBubbleTemplate">
            <Grid HorizontalAlignment="Stretch" Margin="2,3,86,3">
                <Border Background="{ThemeResource VgSurfaceBrush}"
                        CornerRadius="2"
                        MaxWidth="292"
                        HorizontalAlignment="Left"
                        Padding="0">
                    <StackPanel>
                        <Grid Width="280"
                              Height="120"
                              Background="{ThemeResource VgSurface2Brush}">
                            <Border Width="1" Background="#33FFFFFF" HorizontalAlignment="Center" />
                            <Border Height="1" Background="#33FFFFFF" VerticalAlignment="Center" />
                            <Ellipse Width="14"
                                     Height="14"
                                     Fill="{ThemeResource VgAccentBrush}"
                                     Stroke="White"
                                     StrokeThickness="2"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center" />
                            <TextBlock Text="{Binding LocationCoordinates}"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Bottom"
                                       Margin="8" />
                        </Grid>
                        <StackPanel Margin="12,8,12,8">
                            <TextBlock Text="{Binding LocationLabel}" FontSize="14" FontWeight="SemiBold" Foreground="White" TextTrimming="CharacterEllipsis" />
                            <TextBlock Text="{Binding LocationAddress}" FontSize="12" Foreground="#B3FFFFFF" TextWrapping="Wrap"
                                       Visibility="{Binding LocationAddress, Converter={StaticResource StringNotEmptyToVisibility}}" />
                            <HyperlinkButton NavigateUri="{Binding LocationMapUri}"
                                             Padding="0"
                                             Margin="0,4,0,0"
                                             HorizontalAlignment="Left"
                                             Visibility="{Binding LocationCoordinates, Converter={StaticResource StringNotEmptyToVisibility}}">
                                <TextBlock Text="Open map" FontSize="12" Foreground="{ThemeResource VgAccentBrush}" />
                            </HyperlinkButton>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </DataTemplate>

        <!-- Poll: bar chart icon + question + summary -->
        <DataTemplate x:Key="PollBubbleTemplate">
            <StackPanel>
                <TextBlock Text="{Binding AuthorLabel}"
                           Visibility="{Binding ShowAuthor, Converter={StaticResource BoolToVisibility}}"
                           Margin="14,6,86,0"
                           FontFamily="{StaticResource VgFont}"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="{ThemeResource VgAccentBrush}" />
                <bubbles:PollBubble Question="{Binding PollQuestion}"
                                    Options="{Binding PollOptions}"
                                    TotalVoters="{Binding PollTotalVoters}"
                                    IsClosed="{Binding PollIsClosed}"
                                    CanVote="{Binding PollCanVote}"
                                    ShowResults="{Binding PollShowResults}"
                                    VotedOptionIndex="{Binding PollVotedOptionIndex}"
                                    IsOutgoing="{Binding IsOutgoing}" />
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="10,0,12,4">
                    <TextBlock Text="{Binding TimeLabel}" FontSize="11" Foreground="#B3FFFFFF" />
                    <TextBlock Text="{Binding StatusLabel}" FontSize="11" Margin="5,0,0,0" Foreground="#D2FFFFFF" />
                </StackPanel>
            </StackPanel>
        </DataTemplate>

        <!-- WebPage: link card with site, title, description -->
        <DataTemplate x:Key="WebPageBubbleTemplate">
            <Grid HorizontalAlignment="Stretch" Margin="2,3,86,3">
                <Border Background="{ThemeResource VgSurfaceBrush}"
                        CornerRadius="2"
                        MaxWidth="292"
                        HorizontalAlignment="Left"
                        Padding="12,10,14,10">
                    <StackPanel>
                        <TextBlock Text="{Binding Text}" FontSize="14" Foreground="White" TextWrapping="Wrap"
                                   Visibility="{Binding Text, Converter={StaticResource StringNotEmptyToVisibility}}" />
                        <Image Source="{Binding WebPageThumbPath, Converter={StaticResource ImagePathToImageSource}}"
                               Stretch="UniformToFill"
                               Height="112"
                               Margin="0,8,0,0"
                               Visibility="{Binding WebPageThumbPath, Converter={StaticResource StringNotEmptyToVisibility}}" />
                        <Border BorderBrush="{ThemeResource VgAccentBrush}" BorderThickness="3,0,0,0" Margin="0,6,0,0" Padding="8,2,0,2">
                            <StackPanel>
                                <TextBlock Text="{Binding WebPageSiteName}" FontSize="11" FontWeight="SemiBold" Foreground="{ThemeResource VgAccentBrush}"
                                           Visibility="{Binding WebPageSiteName, Converter={StaticResource StringNotEmptyToVisibility}}" />
                                <TextBlock Text="{Binding WebPageTitle}" FontSize="14" FontWeight="SemiBold" Foreground="White" TextWrapping="Wrap"
                                           Visibility="{Binding WebPageTitle, Converter={StaticResource StringNotEmptyToVisibility}}" />
                                <TextBlock Text="{Binding WebPageDescription}" FontSize="12" Foreground="#B3FFFFFF" TextWrapping="Wrap"
                                           Visibility="{Binding WebPageDescription, Converter={StaticResource StringNotEmptyToVisibility}}" />
                                <HyperlinkButton NavigateUri="{Binding WebPageUri}"
                                                 Padding="0"
                                                 HorizontalAlignment="Left"
                                                 Visibility="{Binding WebPageDisplayUrl, Converter={StaticResource StringNotEmptyToVisibility}}">
                                    <TextBlock Text="{Binding WebPageDisplayUrl}" FontSize="12" Foreground="{ThemeResource VgAccentBrush}" TextTrimming="CharacterEllipsis" />
                                </HyperlinkButton>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>
        </DataTemplate>

        <!-- Service: centered grey label, no bubble -->
        <DataTemplate x:Key="ServiceBubbleTemplate">
            <Grid HorizontalAlignment="Stretch" Margin="0,8,0,8">
                <Border Background="{ThemeResource VgSurface2Brush}"
                        CornerRadius="10"
                        Padding="10,4,10,4"
                        HorizontalAlignment="Center">
                    <TextBlock Text="{Binding Text}"
                               FontSize="11"
                               Foreground="{ThemeResource VgFg2Brush}"
                               HorizontalAlignment="Center" />
                </Border>
            </Grid>
        </DataTemplate>

        <!-- Unsupported: decoded constructor/debug hint -->
        <DataTemplate x:Key="UnsupportedBubbleTemplate">
            <Grid HorizontalAlignment="Stretch" Margin="2,3,86,3">
                <Border Background="{ThemeResource VgSurfaceBrush}"
                        CornerRadius="2"
                        MaxWidth="292"
                        HorizontalAlignment="Left"
                        Padding="12,8,14,8">
                    <StackPanel>
                        <TextBlock Text="Message type pending decoder" FontSize="13" FontStyle="Italic" Foreground="#B3FFFFFF" />
                        <TextBlock Text="{Binding UnsupportedHint}" FontSize="10" Foreground="#80FFFFFF" Margin="0,2,0,0"
                                   Visibility="{Binding UnsupportedHint, Converter={StaticResource StringNotEmptyToVisibility}}" />
                    </StackPanel>
                </Border>
            </Grid>
        </DataTemplate>

        <!-- Day separator: centered chip with relative date label
             ("today", "yesterday", "Mon Apr 14", "2024-12-03"). -->
        <DataTemplate x:Key="DaySeparatorTemplate">
            <Grid HorizontalAlignment="Stretch" Margin="0,12,0,8">
                <Border Background="{ThemeResource VgSurface2Brush}"
                        CornerRadius="11"
                        Padding="12,4,12,4"
                        HorizontalAlignment="Center">
                    <TextBlock Text="{Binding Text}"
                               FontSize="11"
                               FontWeight="SemiBold"
                               CharacterSpacing="50"
                               Foreground="{ThemeResource VgFg2Brush}"
                               HorizontalAlignment="Center" />
                </Border>
            </Grid>
        </DataTemplate>

        <bubbles:MessageBubbleTemplateSelector
            x:Key="VgMessageBubbleSelector"
            DaySeparatorTemplate="{StaticResource DaySeparatorTemplate}"
            TextTemplate="{StaticResource TextBubbleTemplate}"
            PhotoTemplate="{StaticResource PhotoBubbleTemplate}"
            VoiceTemplate="{StaticResource VoiceBubbleTemplate}"
            AudioTemplate="{StaticResource AudioBubbleTemplate}"
            VideoTemplate="{StaticResource VideoBubbleTemplate}"
            VideoNoteTemplate="{StaticResource VideoBubbleTemplate}"
            AnimationTemplate="{StaticResource VideoBubbleTemplate}"
            DocumentTemplate="{StaticResource DocumentBubbleTemplate}"
            StickerTemplate="{StaticResource StickerBubbleTemplate}"
            ContactTemplate="{StaticResource ContactBubbleTemplate}"
            LocationTemplate="{StaticResource LocationBubbleTemplate}"
            PollTemplate="{StaticResource PollBubbleTemplate}"
            WebPageTemplate="{StaticResource WebPageBubbleTemplate}"
            ServiceTemplate="{StaticResource ServiceBubbleTemplate}"
            UnsupportedTemplate="{StaticResource UnsupportedBubbleTemplate}" />
    </Page.Resources>

    <Grid Background="{ThemeResource VgBgBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Height="84"
                Padding="8,14,8,8"
                Background="{ThemeResource VgBgBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="48" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="44" />
                    <ColumnDefinition Width="44" />
                </Grid.ColumnDefinitions>

            <controls:AvatarCircle Grid.Column="0"
                                   AvatarSize="42"
                                   Initials="{Binding PeerInitials}"
                                   Image="{Binding PeerAvatarImage}"
                                   ColorSeed="{Binding PeerColorSeed}"
                                   Tapped="OnHeaderTapped"
                                   VerticalAlignment="Center" />

            <StackPanel Grid.Column="1"
                        Margin="8,0,6,0"
                        Tapped="OnHeaderTapped"
                        VerticalAlignment="Center">
                <TextBlock Text="{Binding PeerTitle}"
                           FontFamily="{StaticResource VgFont}"
                           FontSize="17"
                           FontWeight="SemiBold"
                           Foreground="{ThemeResource VgFgBrush}"
                           TextTrimming="CharacterEllipsis" />
                <TextBlock Text="{Binding StatusText}"
                           Style="{StaticResource VgCaptionStyle}"
                           Foreground="{ThemeResource VgFg2Brush}"
                           TextTrimming="CharacterEllipsis"
                           Margin="0,1,0,0" />
            </StackPanel>

            <Button Grid.Column="2"
                    Style="{StaticResource VgIconButtonStyle}"
                    VerticalAlignment="Center">
                <Viewbox Width="21" Height="21">
                    <Path Data="{StaticResource VgGlyphPhone}"
                          Stroke="{ThemeResource VgFgBrush}"
                          StrokeThickness="1.8"
                          StrokeLineJoin="Round"
                          StrokeStartLineCap="Round"
                          StrokeEndLineCap="Round"
                          Width="24"
                          Height="24"
                          Stretch="None" />
                </Viewbox>
            </Button>

            <Button Grid.Column="3"
                    Style="{StaticResource VgIconButtonStyle}"
                    VerticalAlignment="Center">
                <Viewbox Width="22" Height="22">
                    <Path Data="{StaticResource VgGlyphVideo}"
                          Stroke="{ThemeResource VgFgBrush}"
                          StrokeThickness="1.8"
                          StrokeLineJoin="Round"
                          StrokeStartLineCap="Round"
                          StrokeEndLineCap="Round"
                          Width="24"
                          Height="24"
                          Stretch="None" />
                </Viewbox>
            </Button>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Text="{Binding DayLabel}"
                       Style="{StaticResource VgDateSeparatorTextStyle}" />

            <ListView Grid.Row="1"
                      x:Name="MessageList"
                      ItemsSource="{Binding Messages}"
                      SelectionMode="None"
                      Padding="10,0,10,14"
                      ItemContainerStyle="{StaticResource VgStretchListViewItemStyle}"
                      ItemTemplateSelector="{StaticResource VgMessageBubbleSelector}"
                      ScrollViewer.VerticalScrollBarVisibility="Hidden" />

            <!-- Top overlay: older-pagination indicator. Rendered above the
                 ListView's first row so the user sees feedback when scrolling
                 up triggers a paginated history fetch. -->
            <ProgressRing Grid.Row="1"
                          x:Name="OlderLoadingRing"
                          IsActive="{Binding IsLoadingOlder}"
                          Visibility="{Binding IsLoadingOlder, Converter={StaticResource BoolToVisibility}}"
                          Foreground="{ThemeResource VgAccentBrush}"
                          Width="22"
                          Height="22"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Top"
                          Margin="0,8,0,0"
                          IsHitTestVisible="False" />
        </Grid>

        <TextBlock Grid.Row="2"
                   Text="{Binding ErrorMessage}"
                   Style="{StaticResource VgCaptionStyle}"
                   Foreground="{ThemeResource VgDangerBrush}"
                   TextWrapping="Wrap"
                   Margin="24,0,24,8"
                   Visibility="{Binding HasError, Converter={StaticResource BoolToVisibility}}" />

        <Border Grid.Row="3"
                MinHeight="58"
                Padding="8,6,8,6"
                Background="{ThemeResource VgSurfaceBrush}">
            <Grid>
                <Border BorderBrush="{ThemeResource VgDividerBrush}"
                        BorderThickness="0,1,0,0"
                        VerticalAlignment="Top"
                        Margin="-8,-6,-8,0" />

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="42" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="40" />
                        <ColumnDefinition Width="40" />
                        <ColumnDefinition Width="42" />
                    </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Style="{StaticResource VgIconButtonStyle}"
                        Width="40"
                        Height="44"
                        VerticalAlignment="Center">
                    <Viewbox Width="20" Height="20">
                        <Path Data="{StaticResource VgGlyphEmoji}"
                              Stroke="{ThemeResource VgFg2Brush}"
                              StrokeThickness="1.6"
                              StrokeLineJoin="Round"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"
                              Width="24"
                              Height="24"
                              Stretch="None" />
                    </Viewbox>
                </Button>

                <TextBox Grid.Column="1"
                         x:Name="ComposerTextBox"
                         Style="{StaticResource VgComposerTextBoxStyle}"
                         Text="{Binding ComposerText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         PlaceholderText="message"
                         AcceptsReturn="False"
                         KeyDown="OnComposerKeyDown"
                         VerticalAlignment="Center" />

                <Button Grid.Column="2"
                        Style="{StaticResource VgIconButtonStyle}"
                        Width="40"
                        Height="44"
                        VerticalAlignment="Center">
                    <Viewbox Width="21" Height="21">
                        <Path Data="{StaticResource VgGlyphAttach}"
                              Stroke="{ThemeResource VgFgBrush}"
                              StrokeThickness="1.7"
                              StrokeLineJoin="Round"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"
                              Width="24"
                              Height="24"
                              Stretch="None" />
                    </Viewbox>
                </Button>

                <Button Grid.Column="3"
                        Style="{StaticResource VgIconButtonStyle}"
                        Width="40"
                        Height="44"
                        VerticalAlignment="Center">
                    <Viewbox Width="21" Height="21">
                        <Path Data="{StaticResource VgGlyphMic}"
                              Stroke="{ThemeResource VgFgBrush}"
                              StrokeThickness="1.7"
                              StrokeLineJoin="Round"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"
                              Width="24"
                              Height="24"
                              Stretch="None" />
                    </Viewbox>
                </Button>

                <Button Grid.Column="4"
                        x:Name="SendButton"
                        Style="{StaticResource VgIconButtonStyle}"
                        Width="40"
                        Height="44"
                        Click="OnSendClicked"
                        IsEnabled="{Binding CanSend}"
                        VerticalAlignment="Center">
                    <Viewbox Width="22" Height="22">
