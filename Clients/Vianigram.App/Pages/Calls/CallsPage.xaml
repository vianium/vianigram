<Page
    x:Class="Vianigram.App.Pages.Calls.CallsPage"
    x:Name="RootPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Vianigram.App.Controls"
    xmlns:vm="using:Vianigram.App.ViewModels.Pages"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    d:DataContext="{d:DesignInstance Type=vm:CallsPageViewModel, IsDesignTimeCreatable=True}"
    Background="{ThemeResource VgBgBrush}">

    <Page.BottomAppBar>
        <CommandBar DataContext="{Binding DataContext, ElementName=RootPage}">
            <AppBarButton x:Uid="CallsNewCallAppBar"
                          Label="new call"
                          Icon="Add"
                          Command="{Binding NewCallCommand}" />
            <AppBarButton x:Uid="CallsSearchAppBar"
                          Label="search"
                          Icon="Find"
                          Command="{Binding SearchCommand}" />
        </CommandBar>
    </Page.BottomAppBar>

    <Page.Resources>
        <DataTemplate x:Key="CallRowTemplate">
            <Grid MinHeight="56"
                  Margin="8,5,8,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="48" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="44" />
                </Grid.ColumnDefinitions>

                <controls:AvatarCircle Grid.Column="0"
                                       AvatarSize="42"
                                       Initials="{Binding Initials}"
                                       ColorSeed="{Binding AvatarColorSeed}"
                                       VerticalAlignment="Center" />

                <StackPanel Grid.Column="1"
                            Margin="8,0,4,0"
                            VerticalAlignment="Center">
                    <Grid>
                        <TextBlock Text="{Binding PeerName}"
                                   Style="{StaticResource VgRowTitleStyle}"
                                   FontWeight="SemiBold"
                                   TextTrimming="CharacterEllipsis"
                                   Visibility="{Binding NormalNameVisibility}" />
                        <TextBlock Text="{Binding PeerName}"
                                   Style="{StaticResource VgRowTitleStyle}"
                                   Foreground="{ThemeResource VgDangerBrush}"
                                   FontWeight="SemiBold"
                                   TextTrimming="CharacterEllipsis"
                                   Visibility="{Binding MissedNameVisibility}" />
                    </Grid>

                    <StackPanel Orientation="Horizontal"
                                Margin="0,1,0,0">
                        <TextBlock Text="{Binding DirectionGlyph}"
                                   FontSize="11"
                                   FontFamily="Segoe UI Symbol"
                                   Foreground="{Binding DirectionBrush}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,4,0" />
                        <TextBlock Text="{Binding MetaText}"
                                   Style="{StaticResource VgMetaStyle}"
                                   TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                </StackPanel>

                <Button Grid.Column="2"
                        Style="{StaticResource VgIconButtonStyle}"
                        Tag="{Binding}"
                        Click="OnCallActionClicked"
                        VerticalAlignment="Center">
                    <Viewbox Width="20" Height="20">
                        <Grid Width="24" Height="24">
                            <Path Data="{StaticResource VgGlyphPhone}"
                                  Stroke="{ThemeResource VgAccentBrush}"
                                  StrokeThickness="1.6"
                                  StrokeLineJoin="Round"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  Visibility="{Binding PhoneIconVisibility}" />
                            <Path Data="{StaticResource VgGlyphVideo}"
                                  Stroke="{ThemeResource VgAccentBrush}"
                                  StrokeThickness="1.6"
                                  StrokeLineJoin="Round"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  Visibility="{Binding VideoIconVisibility}" />
                        </Grid>
                    </Viewbox>
                </Button>
            </Grid>
        </DataTemplate>
    </Page.Resources>

    <Grid Background="{ThemeResource VgBgBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0"
                    Margin="18,20,18,0">
            <TextBlock x:Uid="CallsAppName"
                       Text="VIANIGRAM"
                       Style="{StaticResource VgAppNameStyle}" />
            <TextBlock x:Uid="CallsTitle"
                       Text="calls"
                       Style="{StaticResource VgPageTitleStyle}"
                       Margin="0,12,0,0" />
        </StackPanel>

        <Pivot Grid.Row="1"
               Grid.RowSpan="2"
               Margin="0,-4,0,0"
               Foreground="{ThemeResource VgFgBrush}"
               Background="{ThemeResource VgBgBrush}">
            <PivotItem x:Uid="CallsAllPivot"
                       Header="all">
                <Grid>
                    <ListView ItemsSource="{Binding AllCalls}"
                              SelectionMode="None"
                              IsItemClickEnabled="True"
                              ItemClick="OnCallItemClick"
                              ItemTemplate="{StaticResource CallRowTemplate}"
                              ItemContainerStyle="{StaticResource VgStretchListViewItemStyle}"
                              Margin="0,6,0,0" />
                    <TextBlock x:Uid="CallsAllEmptyText"
                               Text="no calls yet"
                               Style="{StaticResource VgCaptionStyle}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Visibility="{Binding ShowAllEmpty, Converter={StaticResource BoolToVisibility}}" />
                </Grid>
            </PivotItem>

            <PivotItem x:Uid="CallsMissedPivot"
                       Header="missed">
                <Grid>
                    <ListView ItemsSource="{Binding MissedCalls}"
                              SelectionMode="None"
                              IsItemClickEnabled="True"
                              ItemClick="OnCallItemClick"
                              ItemTemplate="{StaticResource CallRowTemplate}"
                              ItemContainerStyle="{StaticResource VgStretchListViewItemStyle}"
                              Margin="0,6,0,0" />
                    <TextBlock x:Uid="CallsMissedEmptyText"
                               Text="no missed calls"
                               Style="{StaticResource VgCaptionStyle}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Visibility="{Binding ShowMissedEmpty, Converter={StaticResource BoolToVisibility}}" />
                </Grid>
            </PivotItem>
        </Pivot>

        <TextBlock Grid.Row="3"
                   Text="{Binding ErrorMessage}"
                   Style="{StaticResource VgCaptionStyle}"
                   Foreground="{ThemeResource VgDangerBrush}"
                   TextWrapping="Wrap"
                   Margin="18,4,18,12"
                   Visibility="{Binding HasError, Converter={StaticResource BoolToVisibility}}" />
    </Grid>
</Page>
