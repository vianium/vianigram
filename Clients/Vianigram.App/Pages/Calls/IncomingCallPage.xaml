<Page
    x:Class="Vianigram.App.Pages.Calls.IncomingCallPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Vianigram.App.Controls"
    xmlns:vm="using:Vianigram.App.ViewModels.Pages"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    d:DataContext="{d:DesignInstance Type=vm:IncomingCallPageViewModel, IsDesignTimeCreatable=True}"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Caller info -->
        <StackPanel Grid.Row="0"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center">
            <controls:AvatarCircle AvatarSize="160"
                                   Initials="{Binding AvatarLetter, Mode=OneWay}"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,28" />

            <TextBlock Text="{Binding PeerName, Mode=OneWay}"
                       FontSize="32"
                       FontWeight="SemiBold"
                       Foreground="{ThemeResource ApplicationForegroundThemeBrush}"
                       HorizontalAlignment="Center"
                       TextTrimming="CharacterEllipsis"
                       Margin="0,0,0,8" />

            <TextBlock Text="{Binding CallTypeText, Mode=OneWay}"
                       FontSize="18"
                       Foreground="{ThemeResource ApplicationForegroundThemeBrush}"
                       Opacity="0.6"
                       HorizontalAlignment="Center" />
        </StackPanel>

        <!-- Accept / Decline buttons -->
        <Grid Grid.Row="1" Margin="0,0,0,64">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Decline -->
            <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                <Button Width="80"
                        Height="80"
                        Background="#FFF44336"
                        Foreground="White"
                        Padding="0"
                        Command="{Binding DeclineCommand}">
                    <TextBlock Text="&#xE137;"
                               FontFamily="Segoe UI Symbol"
                               FontSize="32" />
                </Button>
                <TextBlock Text="Decline"
                           Foreground="#FFF44336"
                           FontSize="14"
                           HorizontalAlignment="Center"
                           Margin="0,8,0,0" />
            </StackPanel>

            <!-- Accept -->
            <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                <Button Width="80"
                        Height="80"
                        Background="#FF4CAF50"
                        Foreground="White"
                        Padding="0"
                        Command="{Binding AcceptCommand}">
                    <TextBlock Text="&#xE13A;"
                               FontFamily="Segoe UI Symbol"
                               FontSize="32" />
                </Button>
                <TextBlock Text="Accept"
                           Foreground="#FF4CAF50"
                           FontSize="14"
                           HorizontalAlignment="Center"
                           Margin="0,8,0,0" />
            </StackPanel>
        </Grid>
    </Grid>
</Page>
