<Page
    x:Class="Vianigram.App.Pages.Secret.SecretChatPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Vianigram.App.Controls"
    xmlns:vm="using:Vianigram.App.ViewModels.Pages"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    d:DataContext="{d:DesignInstance Type=vm:SecretChatPageViewModel, IsDesignTimeCreatable=True}"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
                Background="{ThemeResource SystemControlBackgroundChromeMediumBrush}"
                Padding="12,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <controls:AvatarCircle Grid.Column="0"
                                       AvatarSize="40"
                                       Initials="{Binding AvatarLetter, Mode=OneWay}"
                                       VerticalAlignment="Center" />

                <!-- Lock glyph -->
                <TextBlock Grid.Column="2"
                           Text="&#xE1F6;"
                           FontFamily="Segoe UI Symbol"
                           FontSize="20"
                           Foreground="#FF4CAF50"
                           VerticalAlignment="Center" />

                <StackPanel Grid.Column="3"
                            VerticalAlignment="Center"
                            Margin="8,0,0,0">
                    <TextBlock Text="{Binding PeerTitle, Mode=OneWay}"
                               FontSize="17"
                               FontWeight="SemiBold"
                               Foreground="{ThemeResource ApplicationForegroundThemeBrush}"
                               TextTrimming="CharacterEllipsis" />
                    <TextBlock Text="{Binding KeyStatusText, Mode=OneWay}"
                               FontSize="12"
                               Opacity="0.7"
                               Foreground="{ThemeResource ApplicationForegroundThemeBrush}" />
                </StackPanel>

                <Button Grid.Column="4"
                        Content="View key"
                        Command="{Binding ViewKeyCommand}"
                        Background="Transparent"
                        Foreground="{ThemeResource ApplicationForegroundThemeBrush}"
                        VerticalAlignment="Center" />
            </Grid>
        </Border>

        <!-- Messages list -->
        <ListView Grid.Row="1"
                  ItemsSource="{Binding Messages}"
                  SelectionMode="None"
                  ScrollViewer.VerticalScrollBarVisibility="Auto">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="Padding" Value="8,4,8,4" />
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="0,2,0,2">
                        <StackPanel Orientation="Vertical"
                                    HorizontalAlignment="{Binding BubbleAlignment}"
                                    MaxWidth="320">
                            <Border CornerRadius="14"
                                    Background="{ThemeResource ListViewItemPlaceholderBackgroundThemeBrush}"
                                    BorderBrush="{ThemeResource ListViewItemSelectedBackgroundThemeBrush}"
                                    BorderThickness="1"
                                    Padding="12,9,12,7">
                                <TextBlock Text="{Binding Text}"
                                           Foreground="{ThemeResource ApplicationForegroundThemeBrush}"
                                           TextWrapping="Wrap"
                                           FontSize="14" />
                            </Border>
                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="{Binding BubbleAlignment}"
                                        Margin="4,2,4,0">
                                <TextBlock Text="{Binding TimeLabel}"
                                           FontSize="11"
                                           Opacity="0.6"
                                           Foreground="{ThemeResource ApplicationForegroundThemeBrush}" />
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- Self-destruct timer indicator -->
        <Border Grid.Row="2"
                Background="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}"
                Padding="12,8"
                Visibility="{Binding HasSelfDestruct, Mode=OneWay}">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="&#xE121;"
                           FontFamily="Segoe UI Symbol"
                           FontSize="16"
                           Foreground="{ThemeResource ApplicationForegroundThemeBrush}"
                           VerticalAlignment="Center" />
                <TextBlock Text="Self-destruct timer:"
                           FontSize="13"
                           Margin="8,0,4,0"
                           Foreground="{ThemeResource ApplicationForegroundThemeBrush}"
                           VerticalAlignment="Center" />
                <TextBlock Text="{Binding SelfDestructLabel, Mode=OneWay}"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Foreground="{ThemeResource ApplicationForegroundThemeBrush}"
                           VerticalAlignment="Center" />
            </StackPanel>
        </Border>

        <!-- Composer row -->
        <Border Grid.Row="3"
                Background="{ThemeResource SystemControlBackgroundChromeMediumBrush}"
                Padding="8,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Background="Transparent"
                        Foreground="{ThemeResource ApplicationForegroundThemeBrush}"
                        Command="{Binding SetSelfDestructTimerCommand}"
                        CommandParameter="60"
                        VerticalAlignment="Center"
                        Padding="6">
                    <TextBlock Text="&#xE121;"
                               FontFamily="Segoe UI Symbol"
                               FontSize="20" />
                </Button>

                <TextBox Grid.Column="1"
                         Text="{Binding ComposerText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         PlaceholderText="Secret message"
                         AcceptsReturn="False"
                         Margin="6,0" />

                <Button Grid.Column="2"
                        Background="{ThemeResource SystemControlBackgroundAccentBrush}"
                        Foreground="White"
                        Command="{Binding SendCommand}"
                        IsEnabled="{Binding CanSend, Mode=OneWay}"
                        VerticalAlignment="Center"
                        Padding="10,6">
                    <TextBlock Text="&#xE122;"
                               FontFamily="Segoe UI Symbol"
                               FontSize="18" />
                </Button>
            </Grid>
        </Border>
    </Grid>
</Page>
