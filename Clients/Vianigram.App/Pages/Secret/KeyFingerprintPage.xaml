<Page
    x:Class="Vianigram.App.Pages.Secret.KeyFingerprintPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Vianigram.App.Controls"
    xmlns:vm="using:Vianigram.App.ViewModels.Pages"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    d:DataContext="{d:DesignInstance Type=vm:KeyFingerprintPageViewModel, IsDesignTimeCreatable=True}"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
                Background="{ThemeResource SystemControlBackgroundChromeMediumBrush}"
                Padding="16,14">
            <TextBlock Text="Key fingerprint"
                       FontSize="18"
                       FontWeight="SemiBold"
                       Foreground="{ThemeResource ApplicationForegroundThemeBrush}"
                       VerticalAlignment="Center" />
        </Border>

        <!-- Body -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollMode="Disabled">
            <StackPanel HorizontalAlignment="Center"
                        Margin="20,20,20,24"
                        MaxWidth="368">

                <controls:AvatarCircle AvatarSize="80"
                                       Initials="{Binding AvatarLetter, Mode=OneWay}"
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,12" />

                <TextBlock Text="{Binding ContactName, Mode=OneWay}"
                           FontSize="20"
                           FontWeight="SemiBold"
                           Foreground="{ThemeResource ApplicationForegroundThemeBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,12" />

                <TextBlock Text="This image and emoji must match those of your contact."
                           TextWrapping="Wrap"
                           TextAlignment="Center"
                           Foreground="{ThemeResource ApplicationForegroundThemeBrush}"
                           Opacity="0.7"
                           FontSize="14"
                           Margin="8,0,8,18" />

                <!-- Emoji rows: 4 rows, 4 emojis each (VM emits a string per row) -->
                <Border Background="{ThemeResource SystemControlBackgroundChromeMediumBrush}"
                        CornerRadius="14"
                        Padding="20,16"
                        Margin="0,0,0,18">
                    <ItemsControl ItemsSource="{Binding EmojiRows}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}"
                                           FontSize="32"
                                           HorizontalAlignment="Center"
                                           TextAlignment="Center"
                                           Margin="0,4,0,4" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Border>

                <!-- Hex fingerprint -->
                <TextBlock Text="{Binding HexFingerprint, Mode=OneWay}"
                           FontFamily="Consolas"
                           FontSize="12"
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           Foreground="{ThemeResource ApplicationForegroundThemeBrush}"
                           Opacity="0.7"
                           Margin="0,0,0,18" />

                <!-- Action buttons -->
                <Button Content="Compare in person"
                        Command="{Binding CompareCommand}"
                        HorizontalAlignment="Stretch"
                        Margin="0,0,0,8" />

                <Button Content="Copy hex fingerprint"
                        Command="{Binding CopyHexCommand}"
                        Background="Transparent"
                        Foreground="{ThemeResource ApplicationForegroundThemeBrush}"
                        HorizontalAlignment="Stretch" />

                <TextBlock Text="{Binding StatusMessage, Mode=OneWay}"
                           Foreground="{ThemeResource ApplicationForegroundThemeBrush}"
                           Opacity="0.6"
                           FontSize="12"
                           HorizontalAlignment="Center"
                           Margin="0,10,0,0"
                           Visibility="{Binding HasStatus, Mode=OneWay}" />
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
