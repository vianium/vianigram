<!--
    Tokens.xaml — Vianigram design tokens (Modern/Metro).

    Mirrors docs/design_system/tokens.css. Brushes that depend on the active
    theme live inside ThemeDictionaries (keys "Default" = dark, "Light").
    Accent / danger / success / sizing tokens are theme-independent.

    Usage from XAML:
        Background="{ThemeResource VgBgBrush}"
        Foreground="{ThemeResource VgFg2Brush}"
        FontFamily="{StaticResource VgFont}"
-->
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ResourceDictionary.ThemeDictionaries>
        <!-- Dark (Default) -->
        <ResourceDictionary x:Key="Default">
            <SolidColorBrush x:Key="VgBgBrush" Color="#000000" />
            <SolidColorBrush x:Key="VgSurfaceBrush" Color="#1F1F1F" />
            <SolidColorBrush x:Key="VgSurface2Brush" Color="#141414" />
            <SolidColorBrush x:Key="VgFgBrush" Color="#FFFFFF" />
            <SolidColorBrush x:Key="VgFg2Brush" Color="#99FFFFFF" />
            <SolidColorBrush x:Key="VgFg3Brush" Color="#66FFFFFF" />
            <SolidColorBrush x:Key="VgDividerBrush" Color="#14FFFFFF" />

            <!-- Compatibility aliases for older pages that still reference
                 Win10/UWP system theme keys unavailable on Windows Phone 8.1. -->
            <SolidColorBrush x:Key="ApplicationPageBackgroundThemeBrush" Color="#000000" />
            <SolidColorBrush x:Key="ApplicationForegroundThemeBrush" Color="#FFFFFF" />
            <SolidColorBrush x:Key="SystemControlBackgroundAccentBrush" Color="#1BA1E2" />
            <SolidColorBrush x:Key="SystemControlBackgroundChromeMediumBrush" Color="#1F1F1F" />
            <SolidColorBrush x:Key="SystemControlBackgroundChromeMediumLowBrush" Color="#141414" />
            <SolidColorBrush x:Key="SystemControlErrorTextForegroundBrush" Color="#E51400" />
            <SolidColorBrush x:Key="SystemControlForegroundAccentBrush" Color="#1BA1E2" />
            <SolidColorBrush x:Key="SystemControlForegroundBaseLowBrush" Color="#66FFFFFF" />
            <SolidColorBrush x:Key="SystemControlHighlightAccentBrush" Color="#1BA1E2" />

            <!-- WP 8.1 TextBox/PasswordBox chrome. The phone template paints
                 TextBoxFocusedBackgroundThemeBrush directly on focus, so these
                 aliases keep input surfaces aligned with the active theme. -->
            <SolidColorBrush x:Key="TextBoxBackgroundThemeBrush" Color="#000000" />
            <SolidColorBrush x:Key="TextBoxFocusedBackgroundThemeBrush" Color="#000000" />
            <SolidColorBrush x:Key="TextBoxBorderThemeBrush" Color="#66FFFFFF" />
            <SolidColorBrush x:Key="TextBoxForegroundThemeBrush" Color="#FFFFFF" />
            <SolidColorBrush x:Key="TextBoxForegroundHeaderThemeBrush" Color="#FFFFFF" />
            <SolidColorBrush x:Key="TextBoxPlaceholderTextThemeBrush" Color="#66FFFFFF" />
            <SolidColorBrush x:Key="TextBoxDisabledBackgroundThemeBrush" Color="#000000" />
            <SolidColorBrush x:Key="TextBoxDisabledBorderThemeBrush" Color="#14FFFFFF" />
            <SolidColorBrush x:Key="TextBoxDisabledForegroundThemeBrush" Color="#66FFFFFF" />
            <SolidColorBrush x:Key="TextBoxDisabledHeaderForegroundThemeBrush" Color="#66FFFFFF" />
            <SolidColorBrush x:Key="TextSelectionHighlightColorThemeBrush" Color="#1BA1E2" />
            <SolidColorBrush x:Key="TextBoxButtonBorderThemeBrush" Color="Transparent" />
            <SolidColorBrush x:Key="TextBoxButtonForegroundThemeBrush" Color="#FFFFFF" />
            <SolidColorBrush x:Key="TextBoxButtonPointerOverBackgroundThemeBrush" Color="#1F1F1F" />
            <SolidColorBrush x:Key="TextBoxButtonPointerOverBorderThemeBrush" Color="Transparent" />
            <SolidColorBrush x:Key="TextBoxButtonPointerOverForegroundThemeBrush" Color="#FFFFFF" />
            <SolidColorBrush x:Key="TextBoxButtonPressedBackgroundThemeBrush" Color="#FFFFFF" />
            <SolidColorBrush x:Key="TextBoxButtonPressedBorderThemeBrush" Color="Transparent" />
            <SolidColorBrush x:Key="TextBoxButtonPressedForegroundThemeBrush" Color="#000000" />
        </ResourceDictionary>

        <!-- Light -->
        <ResourceDictionary x:Key="Light">
            <SolidColorBrush x:Key="VgBgBrush" Color="#FFFFFF" />
            <SolidColorBrush x:Key="VgSurfaceBrush" Color="#F2F2F2" />
            <SolidColorBrush x:Key="VgSurface2Brush" Color="#E8E8E8" />
            <SolidColorBrush x:Key="VgFgBrush" Color="#000000" />
            <SolidColorBrush x:Key="VgFg2Brush" Color="#99000000" />
            <SolidColorBrush x:Key="VgFg3Brush" Color="#66000000" />
            <SolidColorBrush x:Key="VgDividerBrush" Color="#14000000" />

            <!-- Compatibility aliases for older pages that still reference
                 Win10/UWP system theme keys unavailable on Windows Phone 8.1. -->
            <SolidColorBrush x:Key="ApplicationPageBackgroundThemeBrush" Color="#FFFFFF" />
            <SolidColorBrush x:Key="ApplicationForegroundThemeBrush" Color="#000000" />
            <SolidColorBrush x:Key="SystemControlBackgroundAccentBrush" Color="#1BA1E2" />
            <SolidColorBrush x:Key="SystemControlBackgroundChromeMediumBrush" Color="#F2F2F2" />
            <SolidColorBrush x:Key="SystemControlBackgroundChromeMediumLowBrush" Color="#E8E8E8" />
            <SolidColorBrush x:Key="SystemControlErrorTextForegroundBrush" Color="#E51400" />
            <SolidColorBrush x:Key="SystemControlForegroundAccentBrush" Color="#1BA1E2" />
            <SolidColorBrush x:Key="SystemControlForegroundBaseLowBrush" Color="#66000000" />
            <SolidColorBrush x:Key="SystemControlHighlightAccentBrush" Color="#1BA1E2" />

            <!-- WP 8.1 TextBox/PasswordBox chrome. Keep focused inputs light
                 in light theme and dark in Default theme. -->
            <SolidColorBrush x:Key="TextBoxBackgroundThemeBrush" Color="#FFFFFF" />
            <SolidColorBrush x:Key="TextBoxFocusedBackgroundThemeBrush" Color="#FFFFFF" />
            <SolidColorBrush x:Key="TextBoxBorderThemeBrush" Color="#66000000" />
            <SolidColorBrush x:Key="TextBoxForegroundThemeBrush" Color="#000000" />
            <SolidColorBrush x:Key="TextBoxForegroundHeaderThemeBrush" Color="#000000" />
            <SolidColorBrush x:Key="TextBoxPlaceholderTextThemeBrush" Color="#66000000" />
            <SolidColorBrush x:Key="TextBoxDisabledBackgroundThemeBrush" Color="#FFFFFF" />
            <SolidColorBrush x:Key="TextBoxDisabledBorderThemeBrush" Color="#14000000" />
            <SolidColorBrush x:Key="TextBoxDisabledForegroundThemeBrush" Color="#66000000" />
            <SolidColorBrush x:Key="TextBoxDisabledHeaderForegroundThemeBrush" Color="#66000000" />
            <SolidColorBrush x:Key="TextSelectionHighlightColorThemeBrush" Color="#1BA1E2" />
            <SolidColorBrush x:Key="TextBoxButtonBorderThemeBrush" Color="Transparent" />
            <SolidColorBrush x:Key="TextBoxButtonForegroundThemeBrush" Color="#000000" />
            <SolidColorBrush x:Key="TextBoxButtonPointerOverBackgroundThemeBrush" Color="#E8E8E8" />
            <SolidColorBrush x:Key="TextBoxButtonPointerOverBorderThemeBrush" Color="Transparent" />
            <SolidColorBrush x:Key="TextBoxButtonPointerOverForegroundThemeBrush" Color="#000000" />
            <SolidColorBrush x:Key="TextBoxButtonPressedBackgroundThemeBrush" Color="#000000" />
            <SolidColorBrush x:Key="TextBoxButtonPressedBorderThemeBrush" Color="Transparent" />
            <SolidColorBrush x:Key="TextBoxButtonPressedForegroundThemeBrush" Color="#FFFFFF" />
        </ResourceDictionary>
    </ResourceDictionary.ThemeDictionaries>

    <!-- Theme-independent brushes -->
    <SolidColorBrush x:Key="VgAccentBrush" Color="#1BA1E2" />
    <SolidColorBrush x:Key="VgAccentFgBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="VgDangerBrush" Color="#E51400" />
    <SolidColorBrush x:Key="VgSuccessBrush" Color="#60A917" />

    <!-- Spacing / sizes -->
    <x:Double x:Key="VgEdge">24</x:Double>
    <x:Double x:Key="VgListEdge">12</x:Double>
    <x:Double x:Key="VgAppBarHeight">70</x:Double>
    <x:Double x:Key="VgAvatarSize">56</x:Double>
    <x:Double x:Key="VgRowHeight">80</x:Double>

    <!-- Type family -->
    <FontFamily x:Key="VgFont">Segoe UI</FontFamily>
</ResourceDictionary>
