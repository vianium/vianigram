<!--
    Buttons.xaml — Vianigram button + field styles.

    Default WP/UWP Button has a chrome-y template; we strip it down to a flat
    rectangle with a single border ring (Metro feel) and only react with a
    subtle background/foreground swap on press. Three variants:

        VgButtonStyle         — outline (transparent fill, fg-color border)
        VgButtonPrimaryStyle  — filled accent
        VgButtonBlockStyle    — outline, stretched to container width

    Field variants:

        VgFieldStyle          — surface-filled box, used for password-style inputs
        VgFieldUnderlineStyle — bottom-bordered only, used for the phone number

    Lowercase casing is the caller's responsibility (tokens.css uses
    text-transform: lowercase but XAML has no equivalent that preserves
    accessibility — we keep authored text lowercase in .resw).
-->
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Outline button (transparent fill, fg border). -->
    <Style x:Key="VgButtonStyle" TargetType="Button">
        <Setter Property="FontFamily" Value="{StaticResource VgFont}" />
        <Setter Property="FontSize" Value="18" />
        <Setter Property="FontWeight" Value="Light" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{ThemeResource VgFgBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource VgFgBrush}" />
        <Setter Property="BorderThickness" Value="2" />
        <Setter Property="Padding" Value="24,14" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid x:Name="Root" Background="{TemplateBinding Background}">
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup x:Name="CommonStates">
                                <VisualState x:Name="Normal" />
                                <VisualState x:Name="PointerOver" />
                                <VisualState x:Name="Pressed">
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="Root" Storyboard.TargetProperty="Opacity" To="0.6" Duration="0:0:0.08" />
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="Disabled">
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="Root" Storyboard.TargetProperty="Opacity" To="0.4" Duration="0" />
                                    </Storyboard>
                                </VisualState>
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>
                        <Border BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter x:Name="ContentPresenter"
                                              Content="{TemplateBinding Content}"
                                              ContentTemplate="{TemplateBinding ContentTemplate}"
                                              Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Filled accent button. Inherits sizing from the outline variant. -->
    <Style x:Key="VgButtonPrimaryStyle" TargetType="Button" BasedOn="{StaticResource VgButtonStyle}">
        <Setter Property="Background" Value="{ThemeResource VgAccentBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource VgAccentBrush}" />
        <Setter Property="Foreground" Value="{ThemeResource VgAccentFgBrush}" />
    </Style>

    <!-- Outline button forced to fill its container. -->
    <Style x:Key="VgButtonBlockStyle" TargetType="Button" BasedOn="{StaticResource VgButtonStyle}">
        <Setter Property="HorizontalAlignment" Value="Stretch" />
    </Style>

    <!-- Filled-surface text field. -->
    <Style x:Key="VgFieldStyle" TargetType="TextBox">
        <Setter Property="FontFamily" Value="{StaticResource VgFont}" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="Background" Value="{ThemeResource VgSurfaceBrush}" />
        <Setter Property="Foreground" Value="{ThemeResource VgFgBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource VgSurfaceBrush}" />
        <Setter Property="BorderThickness" Value="2" />
        <Setter Property="Padding" Value="16,14" />
    </Style>

    <!-- List-row button: full-bleed transparent, bottom divider, no padding.
         Used for tappable rows that look like settings entries (country,
         language, etc.). Caller provides the Grid content with chevron. -->
    <Style x:Key="VgRowButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{ThemeResource VgFgBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource VgDividerBrush}" />
        <Setter Property="BorderThickness" Value="0,0,0,1" />
        <Setter Property="Padding" Value="0,14" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid x:Name="Root" Background="{TemplateBinding Background}">
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup x:Name="CommonStates">
                                <VisualState x:Name="Normal" />
                                <VisualState x:Name="PointerOver" />
                                <VisualState x:Name="Pressed">
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="Root" Storyboard.TargetProperty="Opacity" To="0.6" Duration="0:0:0.08" />
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="Disabled">
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="Root" Storyboard.TargetProperty="Opacity" To="0.4" Duration="0" />
                                    </Storyboard>
                                </VisualState>
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>
                        <Border BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter Content="{TemplateBinding Content}"
                                              ContentTemplate="{TemplateBinding ContentTemplate}"
                                              Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Underline-only text field (transparent body, bottom rule). -->
    <Style x:Key="VgFieldUnderlineStyle" TargetType="TextBox">
        <Setter Property="FontFamily" Value="{StaticResource VgFont}" />
        <Setter Property="FontSize" Value="22" />
        <Setter Property="FontWeight" Value="Light" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{ThemeResource VgFgBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource VgFg3Brush}" />
        <Setter Property="BorderThickness" Value="0,0,0,2" />
        <Setter Property="Padding" Value="0,8,0,8" />
    </Style>
</ResourceDictionary>
