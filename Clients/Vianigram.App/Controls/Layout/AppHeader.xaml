<UserControl
    x:Class="Vianigram.App.Controls.Layout.AppHeader"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Border Padding="24,8,24,0">
        <StackPanel>
            <TextBlock x:Name="AppNameText"
                       Style="{StaticResource VgAppNameStyle}"
                       Margin="0,0,0,8" />
            <TextBlock x:Name="PageTitleText"
                       Style="{StaticResource VgPageTitleStyle}" />
        </StackPanel>
    </Border>
</UserControl>
