<UserControl
    x:Class="Vianigram.App.Controls.ChatListItem"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Vianigram.App.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    d:DesignHeight="72"
    d:DesignWidth="420">

    <Border MinHeight="72"
            Padding="12,7,12,7"
            Background="Transparent">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

        <Grid Grid.Column="0"
              VerticalAlignment="Center">
            <controls:AvatarCircle x:Name="Avatar"
                                   AvatarSize="48" />
            <Ellipse x:Name="OnlineDot"
                     Width="12"
                     Height="12"
                     HorizontalAlignment="Right"
                     VerticalAlignment="Bottom"
                     Fill="{ThemeResource VgSuccessBrush}"
                     Stroke="{ThemeResource VgBgBrush}"
                     StrokeThickness="2"
                     Visibility="Collapsed" />
        </Grid>

        <StackPanel Grid.Column="2"
                    VerticalAlignment="Center">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="TitleText"
                           Grid.Column="0"
                           FontFamily="{StaticResource VgFont}"
                           FontSize="17"
                           FontWeight="SemiBold"
                           Foreground="{ThemeResource VgFgBrush}"
                           TextTrimming="CharacterEllipsis"
                           MaxLines="1" />

                <TextBlock x:Name="TimeText"
                           Grid.Column="1"
                           FontFamily="{StaticResource VgFont}"
                           FontSize="11"
                           VerticalAlignment="Center"
                           Margin="8,0,0,0"
                           Foreground="{ThemeResource VgFg3Brush}" />
            </Grid>

            <Grid Margin="0,3,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            Margin="0,0,8,0">
                    <TextBlock x:Name="MutedGlyph"
                               Text="&#xE198;"
                               FontFamily="Segoe UI Symbol"
                               FontSize="13"
                               Foreground="{ThemeResource VgFg3Brush}"
                               Visibility="Collapsed"
                               Margin="0,0,5,0" />
                    <TextBlock x:Name="PinnedGlyph"
                               Text="&#xE141;"
                               FontFamily="Segoe UI Symbol"
                               FontSize="13"
                               Foreground="{ThemeResource VgFg3Brush}"
                               Visibility="Collapsed"
                               Margin="0,0,5,0" />
                    <TextBlock x:Name="PreviewText"
                               FontFamily="{StaticResource VgFont}"
                               FontSize="14"
                               Foreground="{ThemeResource VgFg2Brush}"
                               TextTrimming="CharacterEllipsis"
                               MaxLines="1" />
                </StackPanel>

                <controls:UnreadBadge x:Name="UnreadBadgeControl"
                                      Grid.Column="1"
                                      VerticalAlignment="Center" />
            </Grid>
        </StackPanel>
        </Grid>
    </Border>
</UserControl>
