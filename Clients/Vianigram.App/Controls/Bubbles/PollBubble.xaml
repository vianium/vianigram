<UserControl
    x:Class="Vianigram.App.Controls.Bubbles.PollBubble"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    d:DesignWidth="400">

    <Grid x:Name="RootGrid" Margin="10,2,10,2" MaxWidth="336">
        <Border x:Name="BubbleBorder"
                CornerRadius="14"
                Padding="12,9,12,10"
                BorderThickness="1"
                Background="{ThemeResource ListViewItemPlaceholderBackgroundThemeBrush}"
                BorderBrush="{ThemeResource ListViewItemSelectedBackgroundThemeBrush}">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                    <TextBlock Text="&#xE160;"
                               FontFamily="Segoe UI Symbol"
                               FontSize="14"
                               Opacity="0.6"
                               VerticalAlignment="Center"
                               Margin="0,0,6,0"
                               Foreground="{ThemeResource ApplicationForegroundThemeBrush}" />
                    <TextBlock x:Name="PollLabelText"
                               Text="Poll"
                               FontSize="12"
                               Opacity="0.6"
                               Foreground="{ThemeResource ApplicationForegroundThemeBrush}"
                               VerticalAlignment="Center" />
                </StackPanel>

                <TextBlock x:Name="QuestionText"
                           FontSize="16"
                           FontWeight="SemiBold"
                           LineStackingStrategy="BlockLineHeight"
                           LineHeight="20"
                           TextWrapping="Wrap"
                           Foreground="{ThemeResource ApplicationForegroundThemeBrush}"
                           Margin="0,0,0,8" />

                <StackPanel x:Name="OptionsPanel" />

                <TextBlock x:Name="TotalVotesText"
                           FontSize="12"
                           Opacity="0.6"
                           Foreground="{ThemeResource ApplicationForegroundThemeBrush}"
                           Margin="0,8,0,0" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
