<UserControl
    x:Class="Vianigram.App.Controls.Bubbles.VoiceBubble"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid x:Name="RootGrid" Margin="8,2,8,2" MaxWidth="304">
        <Border x:Name="BubbleBorder"
                CornerRadius="14"
                Padding="10,8,10,8"
                BorderThickness="1"
                Background="{ThemeResource ListViewItemPlaceholderBackgroundThemeBrush}"
                BorderBrush="{ThemeResource ListViewItemSelectedBackgroundThemeBrush}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Button x:Name="PlayPauseButton"
                        Grid.Column="0"
                        Width="36"
                        Height="36"
                        Background="Transparent"
                        BorderThickness="0"
                        Padding="0"
                        VerticalAlignment="Center"
                        Click="OnPlayPauseClicked">
                    <Grid>
                        <ProgressRing x:Name="DownloadRing"
                                      Width="22"
                                      Height="22"
                                      IsActive="False"
                                      Visibility="Collapsed" />
                        <TextBlock x:Name="PlayPauseIcon"
                                   Text="&#xE102;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="20"
                                   Foreground="{ThemeResource SystemControlHighlightAccentBrush}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Grid>
                </Button>

                <Grid x:Name="WaveformHitTarget"
                      Grid.Column="1"
                      Height="36"
                      Margin="8,0,8,0"
                      Background="Transparent"
                      Tapped="OnWaveformTapped">
                    <StackPanel x:Name="WaveformPanel"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Height="28" />
                </Grid>

                <TextBlock x:Name="DurationText"
                           Grid.Column="2"
                           FontSize="12"
                           VerticalAlignment="Center"
                           Foreground="{ThemeResource ApplicationForegroundThemeBrush}"
                           Opacity="0.7"
                           Text="0:00" />

                <ProgressBar x:Name="DownloadProgressBar"
                             Grid.Row="1"
                             Grid.ColumnSpan="3"
                             Height="2"
                             Margin="44,5,36,0"
                             Minimum="0"
                             Maximum="100"
                             Visibility="Collapsed" />
            </Grid>
        </Border>

        <MediaElement x:Name="AudioPlayer"
                      AutoPlay="False"
                      Visibility="Collapsed"
                      MediaOpened="OnAudioOpened"
                      MediaEnded="OnAudioEnded"
                      MediaFailed="OnAudioFailed"
                      CurrentStateChanged="OnAudioCurrentStateChanged" />
    </Grid>
</UserControl>
