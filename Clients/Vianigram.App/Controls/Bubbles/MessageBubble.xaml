<UserControl
    x:Class="Vianigram.App.Controls.Bubbles.MessageBubble"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    d:DesignWidth="400">

    <Grid x:Name="RootGrid"
          HorizontalAlignment="Stretch"
          Margin="2,3,86,3">
        <Border x:Name="BubbleBorder"
                MaxWidth="292"
                HorizontalAlignment="Left"
                Padding="12,8,10,8"
                CornerRadius="2"
                Background="{ThemeResource VgSurfaceBrush}">
            <StackPanel>
                <Border x:Name="ReplyHost"
                        BorderThickness="3,0,0,0"
                        Padding="8,0,0,0"
                        Margin="0,0,0,8"
                        Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock x:Name="ReplyAuthorText"
                                   FontFamily="{StaticResource VgFont}"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="White"
                                   TextTrimming="CharacterEllipsis" />
                        <TextBlock x:Name="ReplyPreviewTextBlock"
                                   Style="{StaticResource VgCaptionStyle}"
                                   TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                </Border>

                <TextBlock x:Name="MessageTextBlock"
                           FontFamily="{StaticResource VgFont}"
                           FontSize="16"
                           Foreground="White"
                           TextWrapping="Wrap" />

                <TextBlock x:Name="ReactionsText"
                           FontFamily="{StaticResource VgFont}"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="White"
                           Margin="0,6,0,0"
                           Visibility="Collapsed" />

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Margin="10,3,0,0">
                    <TextBlock x:Name="TimeText"
                               FontFamily="{StaticResource VgFont}"
                               FontSize="11"
                               VerticalAlignment="Center" />
                    <TextBlock x:Name="StatusText"
                               FontFamily="{StaticResource VgFont}"
                               FontSize="11"
                               Margin="5,0,0,0"
                               VerticalAlignment="Center"
                               Visibility="Collapsed" />
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
