<UserControl
    x:Class="Vianigram.App.Controls.Bubbles.PhotoBubble"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid x:Name="RootGrid" MaxWidth="292" Margin="8,2,8,2">
        <Border x:Name="BubbleBorder"
                CornerRadius="12"
                Padding="3"
                BorderThickness="1"
                Background="{ThemeResource ListViewItemPlaceholderBackgroundThemeBrush}"
                BorderBrush="{ThemeResource ListViewItemSelectedBackgroundThemeBrush}">
            <StackPanel>
                <Border x:Name="PhotoBorder"
                        CornerRadius="7"
                        Background="{ThemeResource ListViewItemPlaceholderBackgroundThemeBrush}">
                    <Grid x:Name="PhotoHost"
                          Tapped="OnPhotoTapped">
                        <Image x:Name="PhotoImage"
                               Stretch="UniformToFill"
                               MaxHeight="220"
                               ImageOpened="OnImageOpened"
                               ImageFailed="OnImageFailed" />
                        <Grid x:Name="PlaceholderGrid"
                              MinHeight="118"
                              Background="{ThemeResource ListViewItemPlaceholderBackgroundThemeBrush}">
                            <TextBlock x:Name="PlaceholderGlyph"
                                       Text="&#xE91B;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="40"
                                       Opacity="0.45"
                                       Foreground="{ThemeResource ApplicationForegroundThemeBrush}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Grid>
                        <Grid x:Name="LoadingOverlay"
                              Background="#55000000"
                              Visibility="Collapsed">
                            <StackPanel HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                <ProgressRing x:Name="LoadingRing"
                                              IsActive="False"
                                              Width="32"
                                              Height="32"
                                              Foreground="White" />
                                <ProgressBar x:Name="DownloadProgressBar"
                                             Width="120"
                                             Height="3"
                                             Minimum="0"
                                             Maximum="100"
                                             Margin="0,8,0,0"
                                             Foreground="{ThemeResource SystemControlHighlightAccentBrush}"
                                             Visibility="Collapsed" />
                            </StackPanel>
                        </Grid>
                        <Border x:Name="FailureOverlay"
                                Background="#66000000"
                                Visibility="Collapsed">
                            <StackPanel HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                <TextBlock Text="&#xE783;"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="28"
                                           Foreground="White"
                                           HorizontalAlignment="Center" />
                                <TextBlock Text="Tap to retry"
                                           FontSize="12"
                                           Margin="0,6,0,0"
                                           Foreground="White" />
                            </StackPanel>
                        </Border>
                        <Border x:Name="MediaBadge"
                                Background="#99000000"
                                CornerRadius="10"
                                Padding="8,3"
                                Margin="8"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Bottom"
                                Visibility="Collapsed">
                            <TextBlock x:Name="MediaBadgeText"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="White" />
                        </Border>
                        <Border x:Name="ActionBadge"
                                Width="42"
                                Height="42"
                                Background="#B0000000"
                                CornerRadius="21"
                                Margin="8"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Visibility="Collapsed">
                            <TextBlock x:Name="ActionGlyph"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="20"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Border>
                    </Grid>
                </Border>
                <TextBlock x:Name="CaptionText"
                           TextWrapping="Wrap"
                           FontSize="14"
                           Margin="7,6,7,4"
                           Foreground="{ThemeResource ApplicationForegroundThemeBrush}"
                           Visibility="Collapsed" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
