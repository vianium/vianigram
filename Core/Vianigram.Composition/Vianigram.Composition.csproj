    <!--
      Native WinRT components (.winmd projection). Composition wires the real
      MtProtoConnection (DH handshake) and MtProtoChannel (encrypted RPC) into
      the per-context outbound ports. The crypto / TL / MTProto / VoIP libs
      now live in their own Vianium sibling repos and are referenced by
      relative path. Fixes in those libs flow automatically.
    -->
    <!-- Vianium.Core.Crypto is a StaticLibrary (no .winmd projection). It
         gets statically linked into Vianium.Tls.dll / Vianium.MTProto.dll /
         Vianium.MtProxy.dll, which managed code references directly.
         The SRP-2048 (Telegram 2FA) client surface is exposed through a
         separate WinRT projection (vianium-crypto/winrt) so managed code
         can see Vianium.Crypto.SrpClient. -->
    <ProjectReference Include="..\..\..\vianium-crypto\winrt\Vianium.Core.Crypto.WinRT.vcxproj">
      <Project>{B1C2D3E4-F5A6-47B8-9C0D-1E2F3A4B5C6D}</Project>
      <Name>Vianium.Core.Crypto.WinRT</Name>
      <ReferenceOutputAssembly>true</ReferenceOutputAssembly>
      <!-- AppX packaging gets native VC outputs from the project graph; keeping
           them copy-local here duplicates PDB payloads from Composition\bin. -->
      <Private>false</Private>
    </ProjectReference>
    <ProjectReference Include="..\..\..\vianium-mtproto\Vianium.Tl.vcxproj">
      <Project>{D2E3F4A5-B6C7-4D8E-9F01-A2B3C4D5E6F7}</Project>
      <Name>Vianium.Tl</Name>
      <ReferenceOutputAssembly>true</ReferenceOutputAssembly>
      <Private>false</Private>
    </ProjectReference>
    <ProjectReference Include="..\..\..\vianium-mtproto\Vianium.MTProto.vcxproj">
      <Project>{D3E4F5A6-B7C8-4D9E-9F01-A3B4C5D6E7F8}</Project>
      <Name>Vianium.MTProto</Name>
      <ReferenceOutputAssembly>true</ReferenceOutputAssembly>
      <Private>false</Private>
    </ProjectReference>
    <!-- Vianium.MtProxy WinRT projection — consumed by MtProxyProbe to
         run the live handshake test from the proxy settings page. The
         transitive runtime dependency (Vianium.MtProxy.dll) was already
         pulled in via Vianium.MTProto.vcxproj's ProjectReference; this
         entry exposes the .winmd to managed code for compile-time
